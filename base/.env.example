# =============================================================================
# 湾源农仓本地基础设施环境变量
# 复制为 .env 后按需修改，所有变量都有默认值，省略时使用 docker-compose.yml 里的 ${VAR:-default}
# =============================================================================

# ----- PostgreSQL -----
POSTGRES_DB=farm
POSTGRES_USER=farm
POSTGRES_PASSWORD=farm123456
POSTGRES_PORT=6001

# ----- Redis -----
REDIS_PASSWORD=redis123456
REDIS_PORT=6003

# ----- MinIO -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=6004
MINIO_CONSOLE_PORT=6005
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-01-20T14-49-07Z
MC_IMAGE=quay.io/minio/mc:RELEASE.2025-01-17T23-25-50Z
