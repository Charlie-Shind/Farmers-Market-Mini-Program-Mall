# =============================================================
# 宝塔生产环境 - 后端配置模板
# 上传到服务器后复制为 backend/.env 并修改
# =============================================================

BACKEND_PORT=6002
NODE_ENV=production

# PostgreSQL（宝塔「数据库」中创建后填写）
DATABASE_URL=postgresql://farm:你的数据库密码@127.0.0.1:5432/farm?schema=public

# Redis（宝塔「软件商店」安装 Redis 后填写）
REDIS_URL=redis://:你的Redis密码@127.0.0.1:6379

# JWT（务必改成 32 位以上随机字符串）
JWT_SECRET=请替换为随机长字符串
JWT_ACCESS_EXPIRES_IN=7d
JWT_GUEST_EXPIRES_IN=7d

# 管理后台域名（用于 CORS，多个用英文逗号分隔）
CORS_ALLOWED_ORIGINS=https://admin.你的域名.com

# MinIO / 对象存储（可选；不配置时文件存本地 uploads/）
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=请替换
MINIO_BUCKET=farm-public
MINIO_PUBLIC_BASE_URL=https://cdn.你的域名.com
MINIO_REQUIRED=false

# 本地上传目录（不填则使用 backend/uploads）
UPLOAD_DIR=/www/wwwroot/farm/backend/uploads
FILE_UPLOAD_MAX_SIZE_MB=50

# 微信小程序
WECHAT_MINI_PROGRAM_APP_ID=wx69b18ac09ffc0427
WECHAT_MINI_PROGRAM_SECRET=请替换
WECHAT_MULTI_APP_ID=
WECHAT_MULTI_APP_SECRET=

# 生产环境建议关闭 demo 种子
ENABLE_DEMO_SEED=false
API_MOCK=false
