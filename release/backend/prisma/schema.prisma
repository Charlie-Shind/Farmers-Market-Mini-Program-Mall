generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          BigInt    @id @default(autoincrement())
  openid      String    @unique @db.VarChar(128)
  accountNo   String?   @unique @map("account_no") @db.VarChar(32)
  unionid     String?   @db.VarChar(128)
  nickname    String?   @db.VarChar(64)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(255)
  mobile      String?   @unique @db.VarChar(20)
  gender      Int?      @db.SmallInt
  status      Int       @default(1) @db.SmallInt
  lastLoginAt DateTime?  @map("last_login_at") @db.Timestamp(6)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)

  addresses   UserAddress[]
  roles       UserRole[]
  merchant    Merchant?
  cartItems    CartItem[]
  orders      Order[]
  refunds     RefundApply[]
  favorites   Favorite[]
  userCoupons UserCoupon[]
  pointLogs   PointLog[]
  leaderApplications LeaderApplication[]
  leaderBindings LeaderBinding[]
  leaderCommissions LeaderCommission[]
  communityLeader CommunityLeader?
  messages          UserMessage[]
  chatConversationsAsBuyer    ChatConversation[] @relation("ChatConversationBuyer")
  chatConversationsAsMerchant  ChatConversation[] @relation("ChatConversationMerchant")
  chatMessagesSent            ChatMessage[] @relation("ChatMessageSender")
  chatMessagesReceived        ChatMessage[] @relation("ChatMessageReceiver")
  flashSaleClaims   FlashSaleClaim[]
  groupBuysInitiated GroupBuy[]    @relation("GroupBuyInitiator")
  groupBuyMembers   GroupBuyMember[]
  productReviews    ProductReview[]
  @@map("user")
}

model SystemMessage {
  id            BigInt    @id @default(autoincrement())
  type          String    @db.VarChar(32)
  title         String    @db.VarChar(128)
  summary       String?   @db.VarChar(255)
  contentType   String    @default("JSON") @map("content_type") @db.VarChar(32)
  contentJson   Json?     @map("content_json")
  coverImageUrl String?   @map("cover_image_url") @db.VarChar(255)
  senderType    String    @default("SYSTEM") @map("sender_type") @db.VarChar(32)
  senderId      BigInt?   @map("sender_id")
  bizType       String?   @map("biz_type") @db.VarChar(32)
  bizId         String?   @map("biz_id") @db.VarChar(64)
  publishAt     DateTime  @default(now()) @map("publish_at") @db.Timestamp(6)
  status        String    @default("PUBLISHED") @db.VarChar(32)

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  receipts      UserMessage[]

  @@index([type, publishAt])
  @@index([status, publishAt])
  @@map("system_message")
}

model UserMessage {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  messageId    BigInt    @map("message_id")
  isRead       Boolean   @default(false) @map("is_read")
  readAt       DateTime? @map("read_at") @db.Timestamp(6)
  deliveredAt  DateTime? @map("delivered_at") @db.Timestamp(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(6)

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  user         User           @relation(fields: [userId], references: [id])
  message      SystemMessage   @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId])
  @@index([userId, isRead, createdAt])
  @@index([messageId])
  @@map("user_message")
}

model ChatConversation {
  id             BigInt   @id @default(autoincrement())
  conversationKey String  @unique @map("conversation_key") @db.VarChar(160)
  buyerId        BigInt   @map("buyer_id")
  merchantId     BigInt   @map("merchant_id")
  productId      BigInt?  @map("product_id")
  orderNo        String?  @map("order_no") @db.VarChar(64)
  title          String?  @db.VarChar(128)
  sceneType      String   @default("GENERAL") @map("scene_type") @db.VarChar(32)
  sceneLabel     String   @default("") @map("scene_label") @db.VarChar(128)
  sceneSource    String   @default("") @map("scene_source") @db.VarChar(255)
  lastMessageId  BigInt?  @unique @map("last_message_id")
  lastMessageAt  DateTime @default(now()) @map("last_message_at") @db.Timestamp(6)
  status         String   @default("ACTIVE") @db.VarChar(16)

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(6)

  buyer          User     @relation("ChatConversationBuyer", fields: [buyerId], references: [id])
  merchant       User     @relation("ChatConversationMerchant", fields: [merchantId], references: [id])
  product        Product? @relation(fields: [productId], references: [id])
  lastMessage    ChatMessage? @relation("ChatConversationLastMessage", fields: [lastMessageId], references: [id])
  messages       ChatMessage[]

  @@index([buyerId, lastMessageAt])
  @@index([merchantId, lastMessageAt])
  @@index([orderNo])
  @@index([productId])
  @@map("chat_conversation")
}

model ChatMessage {
  id             BigInt   @id @default(autoincrement())
  conversationId BigInt   @map("conversation_id")
  senderId       BigInt   @map("sender_id")
  receiverId     BigInt   @map("receiver_id")
  senderRole     String   @map("sender_role") @db.VarChar(16)
  contentType    String   @default("TEXT") @map("content_type") @db.VarChar(16)
  content        String   @db.Text
  attachments    Json?    @map("attachments")
  readAt         DateTime? @map("read_at") @db.Timestamp(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(6)

  conversation   ChatConversation @relation(fields: [conversationId], references: [id])
  sender         User      @relation("ChatMessageSender", fields: [senderId], references: [id])
  receiver       User      @relation("ChatMessageReceiver", fields: [receiverId], references: [id])
  lastOfConversation ChatConversation? @relation("ChatConversationLastMessage")

  @@index([conversationId, createdAt])
  @@index([receiverId, readAt])
  @@index([senderId, createdAt])
  @@map("chat_message")
}

model Role {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique @db.VarChar(32)
  name      String   @db.VarChar(64)
  status    Int      @default(1) @db.SmallInt

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  users     UserRole[]

  @@map("role")
}

model UserRole {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role")
}

model UserAddress {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt   @map("user_id")
  receiverName   String   @map("receiver_name") @db.VarChar(64)
  receiverMobile  String   @map("receiver_mobile") @db.VarChar(20)
  province       String   @db.VarChar(64)
  city           String   @db.VarChar(64)
  district       String   @db.VarChar(64)
  detailAddress  String   @map("detail_address") @db.VarChar(255)
  isDefault      Boolean  @default(false) @map("is_default")
  regionCode     String?  @map("region_code") @db.VarChar(12)
  streetName     String?  @map("street_name") @db.VarChar(64)
  latitude       Decimal? @map("latitude") @db.Decimal(10, 6)
  longitude      Decimal? @map("longitude") @db.Decimal(10, 6)
  tag            String?  @map("tag") @db.VarChar(16)

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(6)

  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([regionCode])
  @@map("user_address")
}

model Region {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(12)
  parentCode  String?  @map("parent_code") @db.VarChar(12)
  name        String   @db.VarChar(64)
  shortName   String?  @map("short_name") @db.VarChar(32)
  level       Int      @db.SmallInt
  fullPath    String   @map("full_path") @db.VarChar(255)
  pinyin      String?  @db.VarChar(128)
  latitude    Decimal? @db.Decimal(10, 6)
  longitude   Decimal? @db.Decimal(10, 6)

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([parentCode])
  @@index([level])
  @@map("region")
}

model Merchant {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @unique @map("user_id")
  storeName      String    @map("store_name") @db.VarChar(128)
  storeLogo      String?   @map("store_logo") @db.VarChar(255)
  contactName    String    @map("contact_name") @db.VarChar(64)
  contactMobile  String    @map("contact_mobile") @db.VarChar(20)

  status         Int       @default(2) @db.SmallInt
  commissionRate Decimal?  @map("commission_rate") @db.Decimal(10, 4)
  settledAt      DateTime? @map("settled_at") @db.Timestamp(6)

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(6)

  user            User                 @relation(fields: [userId], references: [id])
  qualifications  MerchantQualification[]
  wallet          MerchantWallet?
  products        Product[]
  productDrafts   MerchantProductDraft[]
  orders          Order[]
  deliveryRecords DeliveryRecord[]
  withdrawApplies WithdrawApply[]
  refunds         RefundApply[]
  productReviews  ProductReview[]

  @@map("merchant")
}

model MerchantQualification {
  id                BigInt   @id @default(autoincrement())
  merchantId        BigInt   @map("merchant_id")
  qualificationType String   @map("qualification_type") @db.VarChar(64)
  fileName          String   @map("file_name") @db.VarChar(255)
  fileUrl           String   @map("file_url") @db.VarChar(255)
  status            Int      @default(2) @db.SmallInt
  auditRemark       String?  @map("audit_remark") @db.VarChar(255)

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  merchant          Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@map("merchant_qualification")
}

model MerchantWallet {
  id                BigInt   @id @default(autoincrement())
  merchantId        BigInt   @unique @map("merchant_id")
  availableBalance  Decimal  @default(0) @map("available_balance") @db.Decimal(18, 2)
  frozenBalance     Decimal  @default(0) @map("frozen_balance") @db.Decimal(18, 2)
  totalIncome       Decimal  @default(0) @map("total_income") @db.Decimal(18, 2)
  totalWithdrawn    Decimal  @default(0) @map("total_withdrawn") @db.Decimal(18, 2)

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  merchant          Merchant @relation(fields: [merchantId], references: [id])

  @@map("merchant_wallet")
}

model WithdrawApply {
  id          BigInt    @id @default(autoincrement())
  merchantId  BigInt    @map("merchant_id")
  applyNo     String    @unique @map("apply_no") @db.VarChar(64)
  amount      Decimal   @db.Decimal(18, 2)
  fee         Decimal   @default(0) @db.Decimal(18, 2)
  status      Int       @default(1) @db.SmallInt
  auditedBy   BigInt?   @map("audited_by")
  auditedAt   DateTime? @map("audited_at") @db.Timestamp(6)
  remark      String?   @db.VarChar(255)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  merchant    Merchant  @relation(fields: [merchantId], references: [id])
  auditor     AdminUser? @relation(fields: [auditedBy], references: [id])

  @@index([merchantId, status])
  @@map("withdraw_apply")
}

model Category {
  id         BigInt    @id @default(autoincrement())
  parentId   BigInt?   @map("parent_id")
  name       String    @db.VarChar(64)
  iconUrl    String?   @map("icon_url") @db.VarChar(255)
  sortOrder  Int       @default(0) @map("sort_order")
  status     Int       @default(1) @db.SmallInt

  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(6)

  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  products   Product[]

  @@index([parentId])
  @@map("category")
}

model Product {
  id           BigInt    @id @default(autoincrement())
  merchantId   BigInt    @map("merchant_id")
  categoryId   BigInt    @map("category_id")
  title        String    @db.VarChar(128)
  subtitle     String?   @db.VarChar(255)
  coverUrl     String?   @map("cover_url") @db.VarChar(255)
  detailDesc   String?   @map("detail_desc") @db.Text
  serviceTags  Json?     @map("service_tags")
  traceInfo    String?   @map("trace_info") @db.Text
  originPlace  String?   @map("origin_place") @db.VarChar(128)
  deliveryType Int?      @map("delivery_type") @db.SmallInt
  status       Int       @default(1) @db.SmallInt
  auditStatus  Int       @default(1) @map("audit_status") @db.SmallInt
  auditRemark  String?   @map("audit_remark") @db.VarChar(255)
  isPreSale    Boolean   @default(false) @map("is_pre_sale")
  isHot        Boolean   @default(false) @map("is_hot")
  groupBuyConfig Json?   @map("group_buy_config")

  // 品牌与商家扩展
  brand        String?   @db.VarChar(64)          // 品牌
  supplierName String?   @map("supplier_name") @db.VarChar(128)  // 供应商名称
  ingredients  String?   @db.Text                 // 配料表/成分
  
  // 规格与尺寸参数
  shelfLife    String?   @map("shelf_life") @db.VarChar(64)     // 保质期
  productionDate String? @map("production_date") @db.VarChar(64) // 生产日期
  material     String?   @db.VarChar(128)         // 材质
  dimensions   String?   @db.VarChar(128)         // 尺寸/规格尺寸
  
  // 备货与配送限制
  leadTime     String?   @map("lead_time") @db.VarChar(64)      // 备货周期
  shippingRestrictedRegions String? @map("shipping_restricted_regions") @db.Text // 限发区域
  afterSalesCommitment String? @map("after_sales_commitment") @db.Text  // 售后承诺
  logisticsCompany     String? @map("logistics_company") @db.VarChar(128) // 快递公司
  
  // 直播与运营属性
  productNature String?  @map("product_nature") @db.VarChar(32)   // 产品性质(主品/副品/福利品)
  liveCities    String?  @map("live_cities") @db.Text             // 可直播城市
  sessionAttribute String? @map("session_attribute") @db.VarChar(64) // 场次属性
  liveMechanism String?  @map("live_mechanism") @db.VarChar(255)  // 直播机制（规格+数量）

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(6)

  merchant     Merchant  @relation(fields: [merchantId], references: [id])
  category     Category  @relation(fields: [categoryId], references: [id])

  skus         ProductSku[]
  images       ProductImage[]
  videos       ProductVideo[]
  traces       ProductTrace[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  favorites    Favorite[]
  flashSaleItems FlashSaleItem[]
  groupBuys    GroupBuy[]
  chatConversations ChatConversation[]
  productReviews ProductReview[]

  @@index([merchantId, status])
  @@index([categoryId, status])
  @@index([auditStatus])
  @@map("product")
}

model ProductSku {
  id            BigInt   @id @default(autoincrement())
  productId     BigInt   @map("product_id")
  skuName       String   @map("sku_name") @db.VarChar(128)
  skuCode       String   @unique @map("sku_code") @db.VarChar(64)
  imageUrl      String?  @map("image_url") @db.VarChar(255)
  specJson      Json?    @map("spec_json")
  price         Decimal  @db.Decimal(18, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(18, 2)
  stock         Int      @default(0)
  lockedStock   Int      @default(0) @map("locked_stock")
  weight        Decimal? @db.Decimal(10, 3)
  status        Int      @default(1) @db.SmallInt
  offlinePrice  Decimal?  @map("offline_price") @db.Decimal(18, 2) // 线下零售销售价
  safetyStock   Int?      @map("safety_stock")                     // 安全库存
  promotionPrice Decimal? @map("promotion_price") @db.Decimal(10, 2) // 促销价
  promotionStartAt DateTime? @map("promotion_start_at")              // 促销开始时间
  promotionEndAt DateTime? @map("promotion_end_at")                  // 促销结束时间

  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp(6)

  product       Product  @relation(fields: [productId], references: [id])
  cartItems     CartItem[]
  orderItems    OrderItem[]
  flashSaleItems FlashSaleItem[]
  groupBuys     GroupBuy[]
  productReviews ProductReview[]

  @@index([productId])
  @@map("product_sku")
}

model ProductImage {
  id         BigInt   @id @default(autoincrement())
  productId  BigInt   @map("product_id")
  imageUrl   String   @map("image_url") @db.VarChar(255)
  sortOrder  Int      @default(0) @map("sort_order")

  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_image")
}

model ProductVideo {
  id         BigInt   @id @default(autoincrement())
  productId  BigInt   @map("product_id")
  videoUrl   String   @map("video_url") @db.VarChar(255)
  coverUrl   String?  @map("cover_url") @db.VarChar(255)
  sortOrder  Int      @default(0) @map("sort_order")

  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_video")
}

model ProductTrace {
  id         BigInt   @id @default(autoincrement())
  productId  BigInt   @map("product_id")
  traceCode  String   @unique @map("trace_code") @db.VarChar(128)
  traceDesc  String?  @map("trace_desc") @db.Text
  traceJson  Json?    @map("trace_json")

  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_trace")
}

model CartItem {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  merchantId BigInt   @map("merchant_id")
  productId  BigInt   @map("product_id")
  skuId      BigInt   @map("sku_id")
  quantity   Int      @default(1)
  checked    Boolean  @default(true)

  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user       User       @relation(fields: [userId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
  sku        ProductSku @relation(fields: [skuId], references: [id])

  @@unique([userId, skuId])
  @@index([userId])
  @@index([merchantId])
  @@map("cart")
}

model Order {
  id              BigInt    @id @default(autoincrement())
  orderNo         String    @unique @map("order_no") @db.VarChar(64)
  parentOrderNo   String?   @map("parent_order_no") @db.VarChar(64)
  isParent        Boolean   @default(false) @map("is_parent")
  userId          BigInt    @map("user_id")
  merchantId      BigInt    @map("merchant_id")
  groupBuyId      BigInt?   @map("group_buy_id")
  addressSnapshot Json      @map("address_snapshot")
  goodsAmount     Decimal   @map("goods_amount") @db.Decimal(18, 2)
  freightAmount   Decimal   @default(0) @map("freight_amount") @db.Decimal(18, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(18, 2)
  payAmount       Decimal   @map("pay_amount") @db.Decimal(18, 2)
  orderStatus     Int       @default(1) @map("order_status") @db.SmallInt
  payStatus       Int       @default(1) @map("pay_status") @db.SmallInt
  deliveryStatus  Int       @default(1) @map("delivery_status") @db.SmallInt
  refundStatus    Int       @default(0) @map("refund_status") @db.SmallInt
  expireAt        DateTime? @map("expire_at") @db.Timestamp(6)
  paidAt          DateTime? @map("paid_at") @db.Timestamp(6)
  completedAt     DateTime? @map("completed_at") @db.Timestamp(6)
  cancelReason    String?   @map("cancel_reason") @db.VarChar(255)
  remark          String?   @db.VarChar(255)
  pickupPointId   BigInt?   @map("pickup_point_id")
  leaderId        BigInt?   @map("leader_id")
  pickupStatus    String?   @map("pickup_status") @db.VarChar(32)
  pickupCode      String?   @map("pickup_code") @db.VarChar(16)
  pickedUpAt      DateTime? @map("picked_up_at") @db.Timestamp(6)

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamp(6)

  user            User       @relation(fields: [userId], references: [id])
  merchant        Merchant   @relation(fields: [merchantId], references: [id])
  items           OrderItem[]
  payments        PaymentRecord[]
  deliveries      DeliveryRecord[]
  refunds         RefundApply[]
  productReviews  ProductReview[]
  pickupPoint     PickupPoint? @relation(fields: [pickupPointId], references: [id])
  leader          CommunityLeader? @relation(fields: [leaderId], references: [id])

  @@index([userId, orderStatus])
  @@index([merchantId, orderStatus])
  @@index([createdAt])
  @@index([parentOrderNo])
  @@index([groupBuyId])
  @@index([leaderId, pickupStatus])
  @@index([pickupPointId])
  @@map("orders")
}

model OrderItem {
  id            BigInt   @id @default(autoincrement())
  orderId       BigInt   @map("order_id")
  productId     BigInt   @map("product_id")
  skuId         BigInt   @map("sku_id")
  productTitle  String   @map("product_title") @db.VarChar(128)
