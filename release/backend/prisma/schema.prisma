  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(6)

  order        Order     @relation(fields: [orderId], references: [id])
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  merchant     Merchant  @relation(fields: [merchantId], references: [id])
  product      Product   @relation(fields: [productId], references: [id])
  sku          ProductSku @relation(fields: [skuId], references: [id])

  @@index([merchantId, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@index([orderId])
  @@map("product_review")
}

// 商家商品发布草稿
// 前端 edit 页在用户编辑过程中"保存草稿"时落库，
// 卸载小程序/换设备/清缓存后可从云端恢复。
// payload 完整保留编辑页 form + specGroups + generatedSkuRows，
// 前端用 applyDraft() 直接灌回编辑状态。
model MerchantProductDraft {
  id          BigInt   @id @default(autoincrement())
  merchantId  BigInt   @map("merchant_id")
  draftNo     String   @unique @map("draft_no") @db.VarChar(32)
  title       String   @db.VarChar(128)
  coverUrl    String?  @map("cover_url") @db.VarChar(255)
  payload     Json     // 完整编辑状态（form / specGroups / generatedSkuRows / selectedCategory / isMultiSpec）
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  merchant    Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId, updatedAt])
  @@index([merchantId, deletedAt])
  @@map("merchant_product_draft")
}
