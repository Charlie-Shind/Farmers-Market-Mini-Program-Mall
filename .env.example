# =============================================================
# Farm 项目统一环境变量模板
# 复制为 .env.local 并按需修改（.env.local 已加入 .gitignore）
# 后端通过 @nestjs/config 读取；admin 通过 Vite 读取（VITE_* / ADMIN_*）；
# wxapp 通过 miniprogram/config/env.config.ts 配置（不入 git）
# =============================================================

# -------------------------------------------------------------
# 基础服务端口
# -------------------------------------------------------------
POSTGRES_PORT=6001
REDIS_PORT=6003
BACKEND_PORT=6002
ADMIN_PORT=6007
CORS_ALLOWED_ORIGINS=http://localhost:6007,http://127.0.0.1:6007

# -------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------
POSTGRES_DB=farm
POSTGRES_USER=farm
POSTGRES_PASSWORD=change-me

# -------------------------------------------------------------
# Redis
# -------------------------------------------------------------
REDIS_PASSWORD=change-me

# -------------------------------------------------------------
# MinIO / S3 兼容对象存储
# -------------------------------------------------------------
MINIO_IMAGE=pgsty/minio:RELEASE.2026-04-17T00-00-00Z
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=6004
MINIO_CONSOLE_PORT=6005
MINIO_CONSOLE_IMAGE=opens3/console@sha256:5cd26c5c3dab49eca5cf1da012e9389db9602e1996f2f4cbffb9d22207a73aae
MINIO_CONSOLE_UI_PORT=6006
CONSOLE_PBKDF_PASSPHRASE=change-me-passphrase
CONSOLE_PBKDF_SALT=change-me-salt
MC_IMAGE=pgsty/mc:RELEASE.2026-04-17T00-00-00Z

# 应用侧 MinIO 连接配置
MINIO_ENDPOINT=localhost
MINIO_PORT=6004
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=farm-public
# 公开访问基础 URL（小程序/管理后台访问图片的根）
MINIO_PUBLIC_BASE_URL=http://localhost:6004

# -------------------------------------------------------------
# 微信小程序
# -------------------------------------------------------------
WECHAT_MINI_PROGRAM_APP_ID=wx1234567890abcdef
WECHAT_MINI_PROGRAM_SECRET=replace-with-your-wechat-mini-program-secret
WECHAT_MULTI_APP_ID=wx1234567890abcdef
WECHAT_MULTI_APP_SECRET=replace-with-your-wechat-multi-program-secret

# 微信开放接口域名（默认官方；如使用代理/测试环境可覆盖）
WECHAT_API_BASE_URL=https://api.weixin.qq.com

# -------------------------------------------------------------
# 业务开关
# -------------------------------------------------------------
API_MOCK=false
# 是否注入 demo 种子数据
ENABLE_DEMO_SEED=true

# -------------------------------------------------------------
# 上传 / 资源路径
# -------------------------------------------------------------
# 文件上传目录（绝对路径）；不填则使用 <backend-cwd>/uploads
UPLOAD_DIR=
# mock 图片资源目录（绝对路径）；不填则按 backend-cwd 向上搜索 mock_images
MOCK_IMAGES_DIR=

# -------------------------------------------------------------
# Demo / Mock 资源 URL 模板
# 仅在数据库无真实数据时作为兜底展示使用
# -------------------------------------------------------------
# 通用 CDN 基础 URL（商品图、Banner、店铺 logo、二维码、分享图）
DEMO_CDN_BASE_URL=https://cdn.example.com
# 溯源页基础 URL
DEMO_TRACE_BASE_URL=https://trace.example.com
# 二维码图片 URL 前缀（默认 ${DEMO_CDN_BASE_URL}/qr）
DEMO_QR_BASE_URL=
# 分享图 URL 前缀（默认 ${DEMO_CDN_BASE_URL}/share）
DEMO_SHARE_BASE_URL=

# -------------------------------------------------------------
# 文件上传
# -------------------------------------------------------------
FILE_UPLOAD_MAX_SIZE_MB=50

# -------------------------------------------------------------
# 管理后台 (admin) —— 通过 Vite 加载
# 可选：覆盖默认值
#   ADMIN_PORT       admin 端口（默认 6007）
#   ADMIN_HOST       admin 监听地址（默认 0.0.0.0）
#   ADMIN_BASE       admin 路由前缀（默认 /admin/）
#   BACKEND_API_URL  后端地址（默认 http://127.0.0.1:6002）
#   VITE_API_BASE    浏览器端 API 前缀（默认 /api/admin）
#   VITE_ADMIN_BASE  浏览器端路由前缀（默认 /admin）
# -------------------------------------------------------------
ADMIN_PORT=6007
ADMIN_HOST=0.0.0.0
ADMIN_BASE=/admin/
BACKEND_API_URL=http://127.0.0.1:6002
VITE_API_BASE=/api/admin
VITE_ADMIN_BASE=/admin
