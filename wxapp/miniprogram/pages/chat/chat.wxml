<view class="phone-page cs-page" style="{{pageStyle}}">
  <view wx:if="{{loading}}" class="cs-state">
    <view class="cs-state__orb">
      <image class="cs-state__icon" src="{{supportIcon}}" mode="aspectFit"></image>
    </view>
    <text class="cs-state__title">正在接入客服</text>
    <text class="cs-state__desc">{{pageHint}}</text>
  </view>

  <!-- 商户：会话列表 -->
  <view wx:elif="{{role === 'merchant' && activeConversationId === 0}}" class="cs-list">
    <page-nav title="客服会话" theme="solid" />
    <view class="cs-list__hint">
      <text class="cs-list__hint-title">客户咨询</text>
      <text class="cs-list__hint-meta">{{unreadCount > 0 ? unreadCount + ' 条未读' : '暂无未读'}}</text>
    </view>

    <scroll-view wx:if="{{conversations.length}}" class="cs-list__scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{conversations}}"
        wx:key="conversationId"
        class="cs-conv"
        data-conversation-id="{{item.conversationId}}"
        bindtap="selectConversation"
      >
        <image class="cs-conv__avatar" src="{{item.displayAvatar}}" mode="aspectFill"></image>
        <view class="cs-conv__body">
          <view class="cs-conv__top">
            <text class="cs-conv__name">{{item.displayName}}</text>
            <text class="cs-conv__time">{{item.displayTime}}</text>
          </view>
          <text class="cs-conv__scene">{{item.displayScene}}</text>
          <text class="cs-conv__preview">{{item.lastMessageContent || '暂无消息'}}</text>
        </view>
        <text wx:if="{{item.unreadCount > 0}}" class="cs-conv__badge">{{item.unreadCount}}</text>
      </view>
      <view class="cs-spacer"></view>
    </scroll-view>

    <view wx:else class="cs-state cs-state--soft">
      <view class="cs-state__orb">
        <t-icon name="message" size="56rpx" color="#2c4a39"></t-icon>
      </view>
      <text class="cs-state__title">{{pageHint || '暂无会话'}}</text>
      <text class="cs-state__desc">新的咨询会自动出现在这里</text>
    </view>
  </view>

  <!-- 聊天会话 -->
  <view wx:elif="{{activeConversationId > 0}}" class="cs-thread">
    <page-nav title="{{conversationTitle}}" theme="solid" />

    <view class="cs-service">
      <view class="cs-service__avatar">
        <image class="cs-service__img" src="{{supportIcon}}" mode="aspectFit"></image>
      </view>
      <view class="cs-service__copy">
        <text class="cs-service__name">{{conversationSubtitle || '在线客服'}}</text>
        <text class="cs-service__status">
          专属接待 · 一般为即时回复
        </text>
      </view>
    </view>

    <scroll-view
      scroll-y
      scroll-into-view="{{messageAnchorId}}"
      class="cs-messages"
      lower-threshold="80"
      enhanced
      show-scrollbar="{{false}}"
      bindscroll="onMessageScroll"
      bindscrolltolower="onMessageScrollToLower"
      bindscrolltoupper="loadMore"
    >
      <view wx:if="{{messages.length}}" class="cs-messages__inner">
        <view wx:for="{{messages}}" wx:key="messageId" class="cs-msg-wrap">
          <view wx:if="{{item.showTime}}" class="cs-time">
            <text>{{item.displayTime}}</text>
          </view>
          <view class="cs-msg {{item.isMine ? 'is-mine' : 'is-other'}}">
            <image
              class="cs-msg__avatar"
              src="{{item.isMine ? currentUserAvatar : supportIcon}}"
              mode="{{item.isMine ? 'aspectFill' : 'aspectFit'}}"
            />
            <view class="cs-msg__body">
              <text wx:if="{{!item.isMine}}" class="cs-msg__name">{{conversationTitle}}</text>
              <view class="cs-msg__bubble">
                <text wx:if="{{item.contentType === 'TEXT'}}" class="cs-msg__text">{{item.content}}</text>
                <image
                  wx:elif="{{item.contentType === 'IMAGE' && item.attachments && item.attachments.imageUrl}}"
                  class="cs-msg__image"
                  src="{{item.attachments.imageUrl}}"
                  mode="widthFix"
                  bindtap="previewImage"
                  data-url="{{item.attachments.imageUrl}}"
                />
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="cs-empty">
        <view class="cs-empty__orb">
          <image class="cs-empty__icon" src="{{supportIcon}}" mode="aspectFit"></image>
        </view>
        <text class="cs-empty__title">{{loadingMessages ? '正在同步消息…' : '开始与客服沟通吧'}}</text>
        <text class="cs-empty__desc">产地问题、订单售后、活动咨询，都可以直接发给我们</text>
        <view wx:if="{{!loadingMessages}}" class="cs-quick">
          <view
            wx:for="{{quickReplies}}"
            wx:key="*this"
            class="cs-quick__chip"
            data-text="{{item}}"
            bindtap="useQuickReply"
          >{{item}}</view>
        </view>
      </view>

      <view id="{{messageAnchorId}}" class="cs-messages__anchor"></view>
    </scroll-view>

    <view wx:if="{{messages.length}}" class="cs-quick cs-quick--bar">
      <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="cs-quick__scroll">
        <view
          wx:for="{{quickReplies}}"
          wx:key="*this"
          class="cs-quick__chip"
          data-text="{{item}}"
          bindtap="useQuickReply"
        >{{item}}</view>
      </scroll-view>
    </view>

    <view class="cs-composer">
      <button class="cs-composer__media" bindtap="chooseAndSendImage" hover-class="cs-composer__media--hover">
        <t-icon name="plus" size="36rpx" color="#2c4a39"></t-icon>
      </button>
      <view class="cs-composer__field">
        <textarea
          class="cs-composer__input"
          value="{{messageText}}"
          placeholder="描述你的问题，例如物流/退换…"
          auto-height
          maxlength="500"
          bindinput="onInput"
          confirm-type="send"
          bindconfirm="sendMessage"
        />
      </view>
      <button
        class="cs-composer__send {{messageText ? 'is-ready' : ''}}"
        loading="{{sending}}"
        bindtap="sendMessage"
      >发送</button>
    </view>
  </view>

  <view wx:else class="cs-state">
    <view class="cs-state__orb">
      <image class="cs-state__icon" src="{{supportIcon}}" mode="aspectFit"></image>
    </view>
    <text class="cs-state__title">{{pageHint}}</text>
    <text class="cs-state__desc">如果一直打不开，请稍后重试</text>
  </view>
</view>
