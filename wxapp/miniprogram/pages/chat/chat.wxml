<view class="chat-page" style="{{pageStyle}}">
  <view wx:if="{{loading}}" class="chat-loading">
    <text class="chat-loading__title">正在加载…</text>
    <text class="chat-loading__desc">{{pageHint}}</text>
  </view>

  <view wx:elif="{{role === 'merchant' && activeConversationId === 0}}" class="chat-list">
    <view class="chat-page__header">
      <button class="chat-page__back" bindtap="goBack" hover-class="back-btn--hover">
        <t-icon name="back" size="48rpx" color="#ffffff"></t-icon>
      </button>
      <view class="chat-page__header-body">
        <text class="chat-page__title">客服会话</text>
        <text class="chat-page__subtitle">商户客服会话</text>
      </view>
      <text class="chat-page__meta">{{unreadCount > 0 ? unreadCount + ' 条未读' : ' '}}</text>
    </view>

    <view wx:if="{{conversations.length}}" class="chat-list__body">
      <view
        wx:for="{{conversations}}"
        wx:key="conversationId"
        class="chat-conversation-card"
        data-conversation-id="{{item.conversationId}}"
        bindtap="selectConversation"
      >
        <image class="chat-conversation-card__avatar" src="{{item.displayAvatar}}" mode="aspectFill"></image>
        <view class="chat-conversation-card__body">
          <view class="chat-conversation-card__top">
            <text class="chat-conversation-card__name">{{item.displayName}}</text>
            <text class="chat-conversation-card__time">{{item.displayTime}}</text>
          </view>
          <text class="chat-conversation-card__scene">{{item.displayScene}}</text>
          <text class="chat-conversation-card__preview">{{item.lastMessageContent || '暂无消息'}}</text>
        </view>
        <text wx:if="{{item.unreadCount > 0}}" class="chat-conversation-card__badge">{{item.unreadCount}}</text>
      </view>
    </view>

    <view wx:else class="chat-empty">
      <text class="chat-empty__title">{{pageHint || '暂无会话'}}</text>
      <text class="chat-empty__desc">新的咨询会自动出现在这里，并显示来源场景。</text>
    </view>
  </view>

  <view wx:elif="{{activeConversationId > 0}}" class="chat-thread">
    <view class="chat-thread__header">
      <button class="chat-thread__back" bindtap="goBack" hover-class="back-btn--hover">
        <t-icon name="back" size="30rpx"></t-icon>
      </button>
    </view>

    <scroll-view
      scroll-y="true"
      scroll-into-view="{{messageAnchorId}}"
      class="chat-message-list"
      lower-threshold="80"
      enhanced
      show-scrollbar="{{false}}"
      bindscroll="onMessageScroll"
      bindscrolltolower="onMessageScrollToLower"
      bindscrolltoupper="loadMore"
      >
      <view wx:if="{{messages.length}}">
        <view
          wx:for="{{messages}}"
          wx:key="messageId"
          class="chat-message-wrap"
        >
          <view wx:if="{{item.showTime}}" class="chat-time-node">
            <text class="chat-time-node__text">{{item.displayTime}}</text>
          </view>
          <view class="chat-message {{item.isMine ? 'is-mine' : 'is-other'}}">
            <image
              class="chat-message__avatar"
              src="{{item.isMine ? currentUserAvatar : (activeConversation && activeConversation.displayAvatar ? activeConversation.displayAvatar : icons.defaultAvatar)}}"
              mode="aspectFill"
            ></image>
            <view class="chat-message__body">
              <text wx:if="{{!item.isMine}}" class="chat-message__name">{{conversationTitle}}</text>
              <view class="chat-message__bubble">
                <text wx:if="{{item.contentType === 'TEXT'}}" class="chat-message__text">{{item.content}}</text>
                <image
                  wx:elif="{{item.contentType === 'IMAGE' && item.attachments && item.attachments.imageUrl}}"
                  class="chat-message__image"
                  src="{{item.attachments.imageUrl}}"
                  mode="widthFix"
                  bindtap="previewImage"
                  data-url="{{item.attachments.imageUrl}}"
                ></image>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="chat-empty chat-empty--thread">
        <text class="chat-empty__title">{{loadingMessages ? '加载消息中…' : '还没有消息'}}</text>
        <text class="chat-empty__desc">直接发送消息，客服会在这里回复你。</text>
      </view>

      <view id="{{messageAnchorId}}" class="chat-message-list__anchor"></view>
    </scroll-view>

    <view class="chat-composer">
      <button class="chat-composer__media-btn" bindtap="chooseAndSendImage" hover-class="composer-btn--hover">
        <t-icon name="plus" size="36rpx"></t-icon>
      </button>
      <textarea
        class="chat-composer__input"
        value="{{messageText}}"
        placeholder="请输入消息内容"
        auto-height="true"
        maxlength="500"
        bindinput="onInput"
      ></textarea>
      <button class="chat-composer__send" loading="{{sending}}" bindtap="sendMessage">发送</button>
    </view>
  </view>

  <view wx:else class="chat-loading">
    <text class="chat-loading__title">{{pageHint}}</text>
    <text class="chat-loading__desc">如果一直打不开，请稍后重试。</text>
  </view>
</view>
