<view class="phone-page shop-page" style="{{pageStyle}}">
  <page-nav title="{{shop.storeName || '店铺主页'}}" theme="solid" show-back="{{true}}" />

  <scroll-view
    class="shop-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="{{scrollIntoView}}"
    bindscrolltolower="loadMore"
  >
    <!-- 店铺头图卡片 -->
    <view class="shop-hero" id="shop-top">
      <view class="shop-hero__bg"></view>
      <view class="shop-hero__card">
        <view class="shop-hero__main">
          <image
            class="shop-hero__logo"
            src="{{shop.storeLogo || icons.defaultAvatar}}"
            mode="aspectFill"
          />
          <view class="shop-hero__info">
            <text class="shop-hero__name">{{shop.storeName || '加载中…'}}</text>
            <view class="shop-hero__tags">
              <text class="shop-hero__tag">认证店铺</text>
              <text class="shop-hero__tag shop-hero__tag--warm">{{shop.qualificationCount || 0}}项资质</text>
            </view>
            <text wx:if="{{shop.contactName}}" class="shop-hero__contact">联系人 {{shop.contactName}}</text>
          </view>
          <button class="shop-hero__chat" bindtap="contactShop">客服</button>
        </view>

        <text wx:if="{{shop.description}}" class="shop-hero__desc">{{shop.description}}</text>

        <view class="shop-hero__stats">
          <view class="shop-hero__stat">
            <text class="shop-hero__stat-num">{{shop.productCount || 0}}</text>
            <text class="shop-hero__stat-label">在售商品</text>
          </view>
          <view class="shop-hero__stat-line"></view>
          <view class="shop-hero__stat">
            <text class="shop-hero__stat-num">{{shop.totalSales || 0}}</text>
            <text class="shop-hero__stat-label">累计销量</text>
          </view>
          <view class="shop-hero__stat-line"></view>
          <view class="shop-hero__stat">
            <text class="shop-hero__stat-num">{{shop.qualificationCount || 0}}</text>
            <text class="shop-hero__stat-label">资质证书</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 优惠券横滑 -->
    <view class="shop-block" id="shop-coupons">
      <view class="shop-block__head">
        <view>
          <text class="shop-block__title">店铺优惠</text>
          <text class="shop-block__sub">领券下单更划算</text>
        </view>
        <text class="shop-block__extra">{{coupons.length}} 张可领</text>
      </view>

      <scroll-view wx:if="{{coupons.length}}" class="coupon-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{coupons}}"
          wx:key="couponId"
          class="coupon-ticket {{item.received || !item.isActive ? 'is-disabled' : ''}}"
          data-coupon-id="{{item.couponId}}"
          data-received="{{item.received}}"
          data-active="{{item.isActive}}"
          bindtap="onReceiveCoupon"
        >
          <view class="coupon-ticket__main">
            <text class="coupon-ticket__amount">{{item.discountAmount}}</text>
            <view class="coupon-ticket__line"></view>
            <text class="coupon-ticket__rule">满{{item.thresholdAmount}}元可用</text>
          </view>
          <view class="coupon-ticket__gap">
            <view class="coupon-ticket__notch coupon-ticket__notch--top"></view>
            <view class="coupon-ticket__dash"></view>
            <view class="coupon-ticket__notch coupon-ticket__notch--bottom"></view>
          </view>
          <view class="coupon-ticket__action">
            <text class="coupon-ticket__action-text">{{item.received ? '已领取' : item.isActive ? '立即领取' : '已结束'}}</text>
          </view>
        </view>
      </scroll-view>

      <view wx:elif="{{!loading && hasLoaded}}" class="shop-empty">暂无可领优惠券</view>
    </view>

    <!-- 在售商品 -->
    <view class="shop-block shop-block--products" id="shop-products">
      <view class="shop-block__head">
        <view>
          <text class="shop-block__title">全部商品</text>
          <text class="shop-block__sub">共 {{total}} 件好货</text>
        </view>
      </view>

      <view class="shop-sorts">
        <view
          wx:for="{{sortTabs}}"
          wx:key="key"
          class="shop-sort {{productSort === item.key ? 'is-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="selectSort"
        >{{item.label}}</view>
      </view>

      <view wx:if="{{displayProducts.length}}" class="goods-grid">
        <view
          wx:for="{{displayProducts}}"
          wx:key="productId"
          class="goods-card"
          data-product-id="{{item.productId}}"
          bindtap="openProductDetail"
        >
          <image
            wx:if="{{item.coverUrl}}"
            class="goods-card__img"
            src="{{item.coverUrl}}"
            mode="aspectFill"
          />
          <view wx:else class="goods-card__img goods-card__img--empty"></view>
          <view class="goods-card__body">
            <text class="goods-card__title">{{item.title}}</text>
            <view class="goods-card__meta">
              <text wx:if="{{item.originPlace}}" class="goods-card__origin">{{item.originPlace}}</text>
              <text wx:if="{{item.saleCount > 0}}" class="goods-card__sales">已售{{item.saleCount}}</text>
            </view>
            <view class="goods-card__price">
              <text class="goods-card__yen">¥</text>
              <text class="goods-card__num">{{item.minPrice}}</text>
              <text wx:if="{{item.originPrice}}" class="goods-card__origin-price">¥{{item.originPrice}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:elif="{{loading}}" class="shop-empty">商品加载中…</view>
      <view wx:elif="{{hasLoaded}}" class="shop-empty">暂无在售商品</view>

      <view wx:if="{{loadingMore}}" class="shop-more">加载中…</view>
      <view wx:elif="{{noMore && displayProducts.length}}" class="shop-more">— 已展示全部商品 —</view>
    </view>

    <view class="shop-safe"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="shop-dock">
    <view class="shop-dock__action" bindtap="contactShop">
      <t-icon name="support" size="40rpx" color="#333333"></t-icon>
      <text>客服</text>
    </view>
    <view class="shop-dock__action" bindtap="scrollToCoupons">
      <t-icon name="coupon" size="40rpx" color="#333333"></t-icon>
      <text>领券</text>
    </view>
    <view class="shop-dock__action" bindtap="scrollToProducts">
      <t-icon name="shop" size="40rpx" color="#333333"></t-icon>
      <text>全部</text>
    </view>
    <button class="shop-dock__primary" bindtap="scrollToProducts">进店逛逛</button>
  </view>
</view>
