<view class="phone-page cart-page" style="{{pageStyle}}">
  <view class="page-title-bar">
    <view class="page-title-bar__side"></view>
    <text class="page-title-bar__title">购物车</text>
    <button class="text-btn" data-label="编辑购物车" bindtap="openSection">编辑</button>
  </view>

  <view class="panel cart-address" data-label="收货地址" bindtap="openSection">
    <t-icon name="location" size="32rpx"></t-icon>
    <view>
      <text class="cart-address__title">{{cart.address.title}}</text>
      <text class="cart-address__desc">{{cart.address.desc}}</text>
    </view>
    <t-icon name="chevronRight" size="24rpx" opacity="0.72"></t-icon>
  </view>

  <view class="cart-promo" data-label="去凑单" bindtap="openSection">
    <text class="cart-promo__text">{{cart.promo.text}}</text>
    <view class="cart-promo__action">
      <text>{{cart.promo.actionLabel}}</text>
      <t-icon name="chevronRight" size="24rpx" color="#c67a3c"></t-icon>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">
      <text class="section-title__title">{{cart.shopName}}</text>
      <button class="section-more" data-label="去凑单" bindtap="openSection">
        <text>去凑单</text>
        <t-icon name="chevronRight" size="24rpx" opacity="0.72"></t-icon>
      </button>
    </view>
    <block wx:if="{{cart.items.length}}">
      <view wx:for="{{cart.items}}" wx:key="id" class="cart-item">
        <view class="check {{item.checked ? 'check--active' : ''}}" data-cart-id="{{item.id}}" data-checked="{{item.checked}}" bindtap="toggleItem">
          <t-icon wx:if="{{item.checked}}" name="check" size="24rpx" color="#ffffff"></t-icon>
        </view>
        <view class="cart-img {{item.imageClass}}" style="{{item.imageStyle}}"></view>
        <view class="cart-info">
          <text class="cart-title">{{item.title}}</text>
          <text class="cart-desc">{{item.desc}}</text>
          <view class="cart-line">
            <text class="cart-price">{{item.price}}</text>
            <view class="qty">
              <button data-cart-id="{{item.id}}" data-quantity="{{item.quantity}}" bindtap="decreaseItem">
                <t-icon name="minus" size="24rpx"></t-icon>
              </button>
              <text>{{item.quantity}}</text>
              <button data-cart-id="{{item.id}}" data-quantity="{{item.quantity}}" bindtap="increaseItem">
                <t-icon name="plus" size="24rpx"></t-icon>
              </button>
            </view>
          </view>
        </view>
      </view>
    </block>
    <view wx:elif="{{loading}}" class="cart-empty-state">
      <text class="cart-empty-state__title">购物车加载中</text>
      <text class="cart-empty-state__desc">正在同步你的商品和地址信息</text>
    </view>
    <view wx:elif="{{loadError}}" class="cart-empty-state">
      <text class="cart-empty-state__title">购物车暂时没加载出来</text>
      <text class="cart-empty-state__desc">下拉刷新或重新进入页面后会再次尝试</text>
    </view>
    <view wx:else class="cart-empty-state">
      <image class="cart-empty-state__image" src="/assets/cart-empty.svg" mode="aspectFit"></image>
      <text class="cart-empty-state__title">购物车空空如也</text>
      <text class="cart-empty-state__desc">先去首页或分类页挑几样好货，再回来结算</text>
      <button class="cart-empty-state__action" data-label="去逛逛" bindtap="openSection">去首页逛逛</button>
    </view>
  </view>

  <!-- 为你推荐 暂时关闭
  <view class="panel">
    <view class="section-title">
      <text class="section-title__title">为你推荐</text>
    </view>
    <view class="recommend-two">
      <view wx:for="{{cart.recommend}}" wx:key="id" class="goods-card" data-id="{{item.id}}" bindtap="openProductDetail">
        <view class="goods-img {{item.imageClass}}" style="{{item.imageStyle}}"></view>
        <text class="goods-title">{{item.title}}</text>
        <text class="goods-desc">{{item.desc}}</text>
        <view class="price-line">
          <text class="price">{{item.price}}</text>
          <button data-id="{{item.id}}" catchtap="addRecommendToCart">
            <t-icon name="cart" size="24rpx"></t-icon>
          </button>
        </view>
      </view>
    </view>
  </view>
  -->

  <view class="cart-spacer"></view>
  <view class="cart-bottom">
    <view class="cart-select">
      <view class="check check--active">
        <t-icon name="check" size="24rpx" color="#ffffff"></t-icon>
      </view>
      <text>全选</text>
    </view>
    <view class="cart-total">
      <text class="cart-discount">已优惠 {{cart.discount}}</text>
      <text class="cart-total-price">合计：{{cart.total}}</text>
    </view>
    <button class="checkout {{checkedItemCount ? '' : 'checkout--disabled'}}" disabled="{{!checkedItemCount}}" data-label="结算" bindtap="openSection">去结算（{{checkedItemCount}}）</button>
  </view>

  <sku-spec-sheet
    show="{{showSpecSheet}}"
    product="{{activeSpecProduct}}"
    bind:close="onCloseSpecSheet"
    bind:confirm="onConfirmSpecSheet"
  ></sku-spec-sheet>
</view>
