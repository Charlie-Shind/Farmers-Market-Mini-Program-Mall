<view class="merchant-page has-tabbar orders-page" style="{{pageStyle}}">
  <view class="page-titlebar">
    <view class="title-block">
      <view class="page-title">订单管理</view>
    </view>
    <text></text>
  </view>

  <view class="top-actions" style="justify-content: space-between;">
    <view class="search-pill" style="flex:1; max-width: 420rpx; height: 64rpx; border-radius: 999rpx; background: var(--merchant-bg); display: flex; align-items: center; gap: 12rpx; padding: 0 20rpx;" bindtap="showSearch">
      <image src="/assets/icons/search.svg" mode="aspectFit" style="width:32rpx;height:32rpx" />
      <text style="font-size:26rpx;color:var(--merchant-text-placeholder)">搜索买家、商品、订单号</text>
    </view>
    <view style="display:flex;gap:16rpx;">
      <view class="icon-action" bindtap="showBill">
        <t-icon name="invoice" size="40rpx"></t-icon>
        <text>账单</text>
      </view>
      <view class="icon-action" bindtap="showFilter">
        <t-icon name="filter" size="40rpx"></t-icon>
        <text>筛选</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="order-tabs" enhanced show-scrollbar="{{false}}">
    <view
      class="order-tab {{item.active ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="name"
      bindtap="onTabTap"
      data-index="{{index}}"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <scroll-view scroll-x class="order-chips" enhanced show-scrollbar="{{false}}">
    <view
      class="order-chip {{item.active ? 'active' : ''}}"
      wx:for="{{filters}}"
      wx:key="name"
      bindtap="onFilterTap"
      data-index="{{index}}"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-head">
        <view class="buyer-info">
          <image class="buyer-avatar" src="{{item.buyerAvatar}}" mode="aspectFill" />
          <view class="buyer-main">
            <text class="buyer-name">{{item.buyerName}}</text>
            <text class="order-time">{{item.time}}</text>
          </view>
        </view>
        <text class="status-pill {{item.statusType}}">{{item.status}}</text>
      </view>

      <view class="goods-row" bindtap="openOrderDetail" data-order-no="{{item.id}}">
        <image class="goods-image" src="{{item.goodsImage}}" mode="aspectFill" />
        <view class="goods-main">
          <text class="goods-title">{{item.goodsTitle}}</text>
          <text class="goods-meta">{{item.goodsMeta}}</text>
          <text class="order-no">{{item.orderNo}}</text>
        </view>
        <view class="goods-side">
          <text class="goods-price">{{item.amount}}</text>
          <text class="goods-count">x{{item.count}}</text>
        </view>
      </view>

      <view class="order-summary">
        <text>{{item.summary}}</text>
        <text class="summary-amount">实收 {{item.amount}}</text>
      </view>

      <view class="order-actions">
        <button class="pill-btn ghost" bindtap="contactBuyer" data-phone="{{item.phone}}">联系买家</button>
        <button class="pill-btn primary" bindtap="handlePrimaryAction" data-action="{{item.primaryAction}}" data-order-no="{{item.id}}">{{item.primaryText}}</button>
      </view>
    </view>
  </view>

  <view class="load-more">下滑加载更多</view>

  <view class="bottom-nav">
    <view class="nav-item {{item.active ? 'active' : ''}}" wx:for="{{nav}}" wx:key="name" bindtap="goPage" data-url="{{item.url}}">
      <view class="icon-box nav-icon">
        <t-icon name="{{item.icon}}" size="40rpx"></t-icon>
      </view>
      <text>{{item.name}}</text>
    </view>
  </view>
</view>
