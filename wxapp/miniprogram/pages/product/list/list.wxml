<view class="phone-page pl-page pl-page--{{sceneTone}}" style="{{pageStyle}}">
  <view class="pl-page__top">
    <page-nav title="{{pageTitle}}" theme="{{navTheme}}" />

    <view class="pl-hero">
      <view class="pl-hero__copy">
        <text class="pl-hero__eyebrow">{{pageEyebrow}}</text>
        <text class="pl-hero__title">{{pageTitle}}</text>
        <text class="pl-hero__desc">{{pageDesc}}</text>
      </view>
      <view class="pl-hero__stat">
        <text class="pl-hero__stat-num">{{loading ? '--' : products.length}}</text>
        <text class="pl-hero__stat-label">件好物</text>
      </view>
    </view>

    <scroll-view class="pl-filters" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{filters}}"
        wx:key="value"
        class="pl-filter {{activeFilter === item.value ? 'is-active' : ''}}"
        data-filter="{{item.value}}"
        bindtap="changeFilter"
      >
        <t-icon wx:if="{{item.icon}}" name="{{item.icon}}" size="24rpx" color="{{activeFilter === item.value ? '#ffffff' : item.iconColor}}"></t-icon>
        <text>{{item.label}}</text>
      </view>
    </scroll-view>

    <scroll-view
      wx:if="{{activeFilter === 'origin' && originPlaces.length}}"
      class="pl-origins"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
    >
      <view
        class="pl-origin {{selectedOrigin === '' ? 'is-active' : ''}}"
        data-origin=""
        bindtap="selectOrigin"
      >全部产地</view>
      <view
        wx:for="{{originPlaces}}"
        wx:key="*this"
        class="pl-origin {{selectedOrigin === item ? 'is-active' : ''}}"
        data-origin="{{item}}"
        bindtap="selectOrigin"
      >{{item}}</view>
    </scroll-view>
  </view>

  <scroll-view
    class="pl-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="loadMore"
  >
    <view wx:if="{{products.length}}" class="pl-grid {{scene === 'hot' ? 'pl-grid--rank' : ''}}">
      <view
        wx:for="{{products}}"
        wx:key="id"
        class="pl-card {{scene === 'hot' ? 'pl-card--rank' : ''}}"
        data-product-id="{{item.id}}"
        bindtap="openProductDetail"
      >
        <view class="pl-card__cover">
          <view class="pl-card__img {{item.imageClass}}" style="{{item.imageStyle}}"></view>
          <text wx:if="{{scene === 'hot'}}" class="pl-card__rank pl-card__rank--{{item.rankTone}}">{{item.rankNo}}</text>
          <text wx:elif="{{scene === 'new' && item.isNew}}" class="pl-card__badge">NEW</text>
        </view>
        <view class="pl-card__body">
          <text class="pl-card__title">{{item.title}}</text>
          <text class="pl-card__desc">{{item.desc}}</text>
          <view class="pl-card__tags">
            <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="pl-card__tag">{{tag}}</text>
          </view>
          <view class="pl-card__foot">
            <view class="pl-card__price-wrap">
              <text class="pl-card__price">{{item.price}}</text>
              <text wx:if="{{scene === 'hot'}}" class="pl-card__sales">已售 {{item.saleCount}}</text>
            </view>
            <view class="pl-card__cta">{{ctaLabel}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{!loading}}" class="pl-empty">
      <view class="pl-empty__orb">
        <t-icon name="{{sceneIcon}}" size="56rpx" color="#2c4a39"></t-icon>
      </view>
      <text class="pl-empty__title">暂无相关商品</text>
      <text class="pl-empty__desc">切换筛选条件或稍后再来看看</text>
    </view>

    <view wx:if="{{loading}}" class="pl-loading">正在挑选好物…</view>

    <view wx:if="{{products.length && (loadingMore || noMore)}}" class="pl-end">
      <view class="pl-end__line"></view>
      <text wx:if="{{loadingMore}}">加载中</text>
      <text wx:else>已经到底了</text>
      <view class="pl-end__line"></view>
    </view>

    <view class="pl-spacer"></view>
  </scroll-view>
</view>
