<view class="phone-page detail-page" style="{{pageStyle}}">
  <image-adaptive-nav
    image-url="{{currentMediaUrl}}"
    bind:back="goBack"
    bind:share="shareProduct"
  ></image-adaptive-nav>

  <scroll-view scroll-y="true" class="detail-scroll" enhanced="true" show-scrollbar="{{false}}">
    <!-- 主图轮播 -->
    <view class="pdd-gallery">
      <swiper class="pdd-gallery__swiper" circular="{{bannerTotal > 1}}" indicator-dots="{{false}}" bindchange="onBannerChange">
        <swiper-item wx:for="{{mediaList}}" wx:key="index">
          <image wx:if="{{item.kind === 'image'}}" class="pdd-gallery__media" src="{{item.src}}" mode="aspectFill"></image>
          <video
            wx:else
            class="pdd-gallery__media"
            src="{{item.src}}"
            poster="{{item.poster}}"
            controls="true"
            show-play-btn="true"
          ></video>
        </swiper-item>
      </swiper>
      <view class="pdd-gallery__index" wx:if="{{bannerTotal > 0}}">
        <text>{{bannerIndex + 1}}/{{bannerTotal}}</text>
      </view>
    </view>

    <!-- 价格卡 -->
    <view class="pdd-price-card">
      <view class="pdd-price-card__main">
        <view class="pdd-price">
          <text class="pdd-price__symbol">¥</text>
          <text class="pdd-price__int">{{displayPriceInteger}}</text>
          <text class="pdd-price__frac" wx:if="{{displayPriceFraction}}">.{{displayPriceFraction}}</text>
        </view>
        <text class="pdd-price__origin" wx:if="{{displayOriginalPrice}}">¥{{displayOriginalPrice}}</text>
        <text class="pdd-price__sales">{{displaySalesText}}</text>
      </view>
      <view class="pdd-title-row">
        <text class="pdd-badge" wx:if="{{product.isPreSale}}">预售</text>
        <text class="pdd-title">{{product.title}}</text>
      </view>
      <text class="pdd-subtitle" wx:if="{{product.subtitle}}">{{product.subtitle}}</text>
      <view class="pdd-tags" wx:if="{{coreTags && coreTags.length}}">
        <text class="pdd-tag" wx:for="{{coreTags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 产地实拍视频 -->
    <view class="pdd-video-card" wx:if="{{product.videos && product.videos.length}}" bindtap="playStoryVideo">
      <view class="pdd-video-card__thumb">
        <image
          class="pdd-video-card__cover"
          src="{{product.videos[0].coverUrl || heroImageUrl || product.coverUrl}}"
          mode="aspectFill"
        ></image>
        <view class="pdd-video-card__play">
          <t-icon name="play" size="24rpx" color="#ffffff"></t-icon>
        </view>
        <text class="pdd-video-card__duration" wx:if="{{product.videos[0].duration}}">{{product.videos[0].duration}}</text>
      </view>
      <view class="pdd-video-card__body">
        <text class="pdd-video-card__title">产地实拍视频</text>
        <text class="pdd-video-card__desc">点击查看商品实拍，看得见的放心</text>
      </view>
      <t-icon name="chevronRight" size="24rpx" color="#bbb"></t-icon>
    </view>

    <!-- 选择规格 -->
    <view class="pdd-cell" wx:if="{{product.skus && product.skus.length}}" bindtap="openSkuDrawerForCart">
      <text class="pdd-cell__label">选择</text>
      <text class="pdd-cell__value">{{selectedSku ? selectedSku.skuName : '请选择规格'}}</text>
      <t-icon name="chevronRight" size="24rpx" color="#bbb"></t-icon>
    </view>

    <!-- 服务保障 -->
    <view class="pdd-cell pdd-cell--service" wx:if="{{storyBadges && storyBadges.length}}">
      <text class="pdd-cell__label">服务</text>
      <view class="pdd-service-list">
        <text class="pdd-service-item" wx:for="{{storyBadges}}" wx:key="key">{{item.title}}</text>
      </view>
    </view>

    <!-- 产地 -->
    <view class="pdd-cell" wx:if="{{product.originPlace}}">
      <text class="pdd-cell__label">产地</text>
      <text class="pdd-cell__value">{{product.originPlace}}</text>
    </view>

    <!-- 店铺 -->
    <view class="pdd-shop" wx:if="{{product.merchant}}" bindtap="openStoreInfo">
      <view class="pdd-shop__avatar">
        <image
          class="pdd-shop__logo"
          src="{{product.merchant.storeLogo || icons.defaultAvatar}}"
          mode="aspectFill"
        ></image>
      </view>
      <view class="pdd-shop__info">
        <text class="pdd-shop__name">{{product.merchant.storeName || '本店商家'}}</text>
        <text class="pdd-shop__desc">{{product.merchant.contactName || '产地直采优选好店'}}</text>
      </view>
      <view class="pdd-shop__btn" catchtap="contactMerchant">进店</view>
    </view>

    <!-- 商品详情 -->
    <view class="pdd-detail">
      <view class="pdd-detail__head">
        <view class="pdd-detail__line"></view>
        <text class="pdd-detail__title">商品详情</text>
        <view class="pdd-detail__line"></view>
      </view>
      <rich-text
        wx:if="{{product.detailIsHtml}}"
        class="pdd-detail__rich"
        nodes="{{product.detailHtml}}"
      ></rich-text>
      <text class="pdd-detail__text" wx:elif="{{product.detailDesc}}">{{product.detailDesc}}</text>
      <text class="pdd-detail__empty" wx:else>商家暂未补充图文详情</text>
      <view class="pdd-detail__images" wx:if="{{!product.detailIsHtml && product.images && product.images.length}}">
        <image
          wx:for="{{product.images}}"
          wx:key="*this"
          class="pdd-detail__img"
          src="{{item}}"
          mode="widthFix"
        ></image>
      </view>
    </view>

    <view class="pdd-bottom-space"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="pdd-bar">
    <view class="pdd-bar__icons">
      <view class="pdd-bar__icon" bindtap="contactMerchant">
        <t-icon name="support" size="40rpx" color="#333"></t-icon>
        <text>客服</text>
      </view>
      <view class="pdd-bar__icon" bindtap="openStoreInfo">
        <t-icon name="shop" size="40rpx" color="#333"></t-icon>
        <text>店铺</text>
      </view>
      <view class="pdd-bar__icon" bindtap="toggleFavorite">
        <t-icon name="favorite" size="40rpx" color="{{product.isFavorite ? '#e02e24' : '#333'}}"></t-icon>
        <text>{{product.isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="pdd-bar__icon" bindtap="navToCart">
        <t-icon name="cart" size="40rpx" color="#333"></t-icon>
        <text>购物车</text>
        <text class="pdd-bar__badge" wx:if="{{cartCount > 0}}">{{cartCount}}</text>
      </view>
    </view>
    <view class="pdd-bar__actions">
      <button class="pdd-bar__cart" bindtap="openSkuDrawerForCart">加入购物车</button>
      <button class="pdd-bar__buy" bindtap="openSkuDrawerForBuy">立即购买</button>
    </view>
  </view>

  <!-- 规格弹层 -->
  <view class="custom-sheet-mask {{activeSheet ? 'custom-sheet-mask--show' : ''}}" bindtap="closeSheet" catchtouchmove="preventTouchMove">
    <view class="custom-sheet {{activeSheet ? 'custom-sheet--show' : ''}}" catchtap="preventBubble">
      <view class="sheet-header">
        <view class="sku-preview-row">
          <image class="sku-img" src="{{(selectedSku && selectedSku.imageUrl) || heroImageUrl || product.coverUrl}}" mode="aspectFill"></image>
          <view class="sku-meta-box">
            <view class="sku-price-row">
              <text class="sku-price-symbol">¥</text>
              <text class="sku-price-val">{{selectedSku ? selectedSku.price : displayPrice}}</text>
            </view>
            <text class="sku-stock-val">库存：{{selectedSku ? selectedSku.stock : totalStock}} 件</text>
            <text class="sku-selected-text">已选：{{selectedSku ? selectedSku.skuName : '请选择规格'}}</text>
            <text class="sku-selected-text" wx:if="{{selectedSkuSpecSummary}}">{{selectedSkuSpecSummary}}</text>
          </view>
        </view>
        <button class="sheet-close-btn" bindtap="closeSheet">
          <t-icon name="close" size="32rpx" opacity="0.8"></t-icon>
        </button>
      </view>

      <scroll-view scroll-y="true" enhanced show-scrollbar="{{false}}" class="sheet-body">
        <view class="spec-section">
          <text class="spec-title">规格</text>
          <view class="spec-list spec-list--sheet">
            <button
              wx:for="{{product.skus || []}}"
              wx:key="id"
              class="spec-btn {{selectedSku && selectedSku.id === item.id ? 'spec-btn--active' : ''}}"
              data-index="{{index}}"
              bindtap="selectSku"
            >
              <view class="spec-btn__main">
                <text>{{item.skuName}}</text>
                <text wx:if="{{item.specSummary}}" class="spec-btn__sub">{{item.specSummary}}</text>
              </view>
            </button>
          </view>
        </view>

        <view class="qty-section">
          <text class="qty-title">购买数量</text>
          <view class="qty-picker">
            <button class="qty-btn" bindtap="decreaseQty">
              <t-icon name="minus" size="24rpx"></t-icon>
            </button>
            <text class="qty-num">{{purchaseQty}}</text>
            <button class="qty-btn" bindtap="increaseQty">
              <t-icon name="plus" size="24rpx"></t-icon>
            </button>
          </view>
        </view>
      </scroll-view>

      <view class="sheet-footer">
        <button class="sheet-confirm-btn" bindtap="confirmSheetAction">确认</button>
      </view>
    </view>
  </view>
</view>
