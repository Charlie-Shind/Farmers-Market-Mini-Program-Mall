<scroll-view scroll-y="true" enhanced show-scrollbar="{{false}}" class="home-scroll" style="height: 100vh;">
<view class="phone-page home-page" style="{{pageStyle}}">
  <!-- 品牌顶栏 -->
  <view class="home-brand" style="{{topSearchStyle}}">
  <view class="home-brand__loc" data-label="定位" bindtap="openSection">
      <t-icon name="location" size="28rpx" color="#2c4a39"></t-icon>
      <text class="home-brand__loc-text">{{home.locationDisplay}}</text>
      <t-icon name="chevronDown" size="18rpx" color="#8a877f"></t-icon>
    </view>
    <view class="home-brand__main">
      <text class="home-brand__name">浔源农仓</text>
      <text class="home-brand__slogan">产地直供 · 新鲜到家</text>
    </view>
    <view style="width: 85px"></view>
  </view>

  <!-- 搜索 -->
  <view class="home-search" bindtap="openSearch" hover-class="home-search--hover">
    <t-icon name="search" size="34rpx" color="#9aa097"></t-icon>
    <text class="home-search__placeholder">{{home.searchPlaceholder}}</text>
    <view class="home-search__btn">搜索</view>
  </view>

  <!-- Banner：非受控 swiper，避免 current 双向绑定造成来回跳动 -->
  <view wx:if="{{home.banners.length}}" class="home-banner">
    <swiper
      class="home-banner__swiper"
      circular="{{home.banners.length > 2}}"
      autoplay="{{bannerAutoplay}}"
      interval="4500"
      duration="400"
      easing-function="easeOutCubic"
      skip-hidden-item-layout
      bindchange="onBannerChange"
      bindanimationfinish="onBannerAnimationFinish"
    >
      <swiper-item wx:for="{{home.banners}}" wx:for-item="banner" wx:key="key">
        <image
          class="home-banner__img"
          src="{{banner.imageUrl}}"
          mode="aspectFill"
          lazy-load="{{false}}"
        />
      </swiper-item>
    </swiper>
    <view class="home-banner__dots" wx:if="{{home.banners.length > 1}}">
      <view
        wx:for="{{home.banners}}"
        wx:key="key"
        class="home-banner__dot {{index === activeBannerIndex ? 'is-active' : ''}}"
      ></view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="home-quick">
    <view class="home-quick__row">
      <view
        wx:for="{{home.quickEntries}}"
        wx:key="id"
        class="home-quick__item"
        data-link-type="{{item.linkType}}"
        data-link-id="{{item.linkId}}"
        data-title="{{item.title}}"
        bindtap="openHomeEntry"
      >
        <image class="home-quick__icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="home-quick__label">{{item.label}}</text>
      </view>
    </view>
    <view class="home-quick__row home-quick__row--scene">
      <view
        wx:for="{{home.sceneEntries}}"
        wx:key="key"
        class="home-quick__item home-quick__item--scene"
        data-link-type="{{item.linkType}}"
        data-title="{{item.label}}"
        bindtap="openHomeEntry"
      >
        <view class="home-quick__badge">
          <t-icon name="{{item.icon}}" size="40rpx" color="#2c4a39"></t-icon>
        </view>
        <text class="home-quick__label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 服务保障条 -->
  <view class="home-trust">
    <view class="home-trust__item">
      <t-icon name="origin" size="36rpx" color="#2c4a39"></t-icon>
      <view class="home-trust__copy">
        <text class="home-trust__title">产地直供</text>
        <text class="home-trust__desc">源头好货</text>
      </view>
    </view>
    <view class="home-trust__divider"></view>
    <view class="home-trust__item">
      <t-icon name="truck" size="36rpx" color="#2c4a39"></t-icon>
      <view class="home-trust__copy">
        <text class="home-trust__title">新鲜当日发</text>
        <text class="home-trust__desc">当日采摘</text>
      </view>
    </view>
    <view class="home-trust__divider"></view>
    <view class="home-trust__item">
      <t-icon name="shield" size="36rpx" color="#2c4a39"></t-icon>
      <view class="home-trust__copy">
        <text class="home-trust__title">品质严选</text>
        <text class="home-trust__desc">层层把关</text>
      </view>
    </view>
    <view class="home-trust__divider"></view>
    <view class="home-trust__item">
      <t-icon name="support" size="36rpx" color="#2c4a39"></t-icon>
      <view class="home-trust__copy">
        <text class="home-trust__title">售后无忧</text>
        <text class="home-trust__desc">贴心服务</text>
      </view>
    </view>
  </view>

  <!-- 智能推荐 -->
  <view class="home-block">
    <view class="home-block__head">
      <view>
        <text class="home-block__title">智能推荐</text>
        <text class="home-block__sub">为你精选的当季好货</text>
      </view>
      <view
        class="home-block__more"
        data-scene="recommend"
        data-label="智能推荐"
        data-target="product-list"
        bindtap="openSection"
      >
        <text>更多</text>
        <t-icon name="chevronRight" size="22rpx" color="#b0aea6"></t-icon>
      </view>
    </view>
    <view class="home-goods">
      <product-card
        wx:for="{{home.recommendations}}"
        wx:key="id"
        product="{{item}}"
        layout="vertical"
        bind:addtocart="addHomeProductToCart"
      ></product-card>
    </view>
  </view>

  <!-- 热销榜单 -->
  <view class="home-block">
    <view class="home-block__head">
      <view>
        <text class="home-block__title">热销榜单</text>
        <text class="home-block__sub">每日精选 · 口碑好货</text>
      </view>
      <view
        class="home-block__more"
        data-scene="hot"
        data-label="热销榜单"
        data-target="product-list"
        bindtap="openSection"
      >
        <text>更多</text>
        <t-icon name="chevronRight" size="22rpx" color="#b0aea6"></t-icon>
      </view>
    </view>
    <view class="home-rank-tabs">
      <view
        wx:for="{{home.rankTabs}}"
        wx:key="key"
        class="home-rank-tab {{item.key === home.activeRankTab ? 'is-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="switchRankTab"
      >{{item.label}}</view>
    </view>
    <view class="home-rank-list">
      <product-card
        wx:for="{{home.hotList}}"
        wx:key="id"
        product="{{item}}"
        layout="rank"
        bind:addtocart="addHomeProductToCart"
      ></product-card>
    </view>
  </view>

  <sku-spec-sheet
    show="{{showSpecSheet}}"
    product="{{activeSpecProduct}}"
    bind:close="onCloseSpecSheet"
    bind:confirm="onConfirmSpecSheet"
  ></sku-spec-sheet>

  <view class="tab-bar-placeholder"></view>
</view>
</scroll-view>
