<view class="phone-page profile-coupons-page" style="{{pageStyle}}">
  <page-nav title="卡券包" theme="solid" />

  <view class="coupon-content">
    <view class="coupon-hero">
      <image class="coupon-hero__bg" src="/assets/images/points/kajuanbg.jpg" mode="aspectFill" />
      <view class="coupon-hero__main">
        <view class="coupon-hero__info">
          <view class="coupon-hero__label-row">
            <t-icon name="coupon" size="26rpx" color="#5c7a5e"></t-icon>
            <text class="coupon-hero__label">可使用卡券</text>
          </view>
          <view class="coupon-hero__value-row">
            <text class="coupon-hero__value">{{summary.available}}</text>
            <text class="coupon-hero__unit">张</text>
          </view>
        </view>
      </view>
      <view class="coupon-hero__stats">
        <view class="coupon-hero__stat">
          <text class="coupon-hero__stat-value">{{summary.total}}</text>
          <text class="coupon-hero__stat-label">全部</text>
        </view>
        <view class="coupon-hero__stat-line"></view>
        <view class="coupon-hero__stat">
          <text class="coupon-hero__stat-value">{{summary.used}}</text>
          <text class="coupon-hero__stat-label">已使用</text>
        </view>
        <view class="coupon-hero__stat-line"></view>
        <view class="coupon-hero__stat">
          <text class="coupon-hero__stat-value">{{summary.expired}}</text>
          <text class="coupon-hero__stat-label">已过期</text>
        </view>
      </view>
    </view>

    <scroll-view scroll-x="true" class="coupon-tabs" show-scrollbar="{{false}}">
      <view class="coupon-tabs__row">
        <view
          wx:for="{{filterTabs}}"
          wx:key="key"
          class="coupon-tab {{activeFilter === item.key ? 'coupon-tab--active' : ''}}"
          data-key="{{item.key}}"
          bindtap="switchFilter"
          hover-class="coupon-tab--hover"
        >
          <text class="coupon-tab__label">{{item.label}}</text>
          <text class="coupon-tab__count">{{item.count}}</text>
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{visibleCoupons.length}}" class="coupon-list">
      <view
        wx:for="{{visibleCoupons}}"
        wx:key="userCouponId"
        class="coupon-card {{item.statusTone}}"
      >
        <view class="coupon-card__main">
          <text class="coupon-card__badge">{{item.name}}</text>
          <view class="coupon-card__amount-row">
            <text class="coupon-card__amount">{{item.discountAmount}}</text>
            <text class="coupon-card__unit">元</text>
          </view>
          <text class="coupon-card__meta-title">满{{item.thresholdAmount}}元可用</text>
          <text class="coupon-card__period">{{item.periodText}}</text>
        </view>
        <view class="coupon-card__gap">
          <view class="coupon-card__notch coupon-card__notch--top"></view>
          <view class="coupon-card__dash"></view>
          <view class="coupon-card__notch coupon-card__notch--bottom"></view>
        </view>
        <view class="coupon-card__footer">
          <text class="coupon-card__action-text">{{item.statusLabel}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="coupon-empty">
      <view class="coupon-empty__icon">
        <t-icon name="coupon" size="52rpx" color="#c7bfa8"></t-icon>
      </view>
      <text class="coupon-empty__title">暂无卡券</text>
      <text class="coupon-empty__desc">当前筛选条件下没有可展示的卡券。</text>
    </view>
  </view>

  <loading show="{{loading}}" text="{{loadingText}}"></loading>
  <view class="bottom-safe"></view>
</view>
