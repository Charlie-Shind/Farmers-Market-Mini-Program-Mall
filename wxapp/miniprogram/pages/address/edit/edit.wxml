<view class="phone-page address-edit-page" style="{{pageStyle}}">
  <!-- Top Navigation Bar -->
  <view class="board-head">
    <view class="page-title-bar">
      <button class="back-btn" bindtap="goBack" hover-class="back-btn--hover">
        <t-icon name="back" size="48rpx" color="#ffffff"></t-icon>
      </button>
      <text class="page-title-bar__title">{{addressId ? '编辑收货地址' : '新增收货地址'}}</text>
      <text></text>
    </view>
  </view>

  <scroll-view scroll-y="true" class="edit-scroll" enhanced="true" show-scrollbar="{{false}}">
    <!-- Form Panels -->
    <view class="panel form-panel">
      <!-- Receiver Name -->
      <view class="form-item">
        <text class="form-label">收货人</text>
        <input class="form-input" placeholder="请填写收货人姓名" value="{{receiverName}}" bindinput="onNameInput" />
      </view>

      <!-- Receiver Mobile -->
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" placeholder="请填写收货人手机号" value="{{receiverMobile}}" bindinput="onMobileInput" />
      </view>

      <!-- Region Selector -->
      <view class="form-item">
        <text class="form-label">所在地区</text>
        <picker class="form-picker" mode="region" bindchange="onRegionChange" value="{{regionValue}}">
          <view class="picker-inner">
            <text class="picker-text" wx:if="{{regionValue.length}}">{{regionValue[0]}} {{regionValue[1]}} {{regionValue[2]}}</text>
            <text class="picker-placeholder" wx:else>点击选择省、市、区</text>
            <t-icon name="chevronRight" size="24rpx" opacity="0.6"></t-icon>
          </view>
        </picker>
      </view>

      <!-- Detail Address -->
      <view class="form-item form-item--textarea">
        <text class="form-label">详细地址</text>
        <textarea class="form-textarea" placeholder="请填写街道、门牌号等详细地址" value="{{detailAddress}}" bindinput="onDetailInput" auto-height="true" maxlength="150" />
      </view>
    </view>

    <!-- Default Option Panel -->
    <view class="panel form-panel default-panel">
      <view class="default-row">
        <view class="default-info">
          <text class="default-title">设为默认地址</text>
          <text class="default-subtitle">每次结算下单时将优先使用此地址</text>
        </view>
        <switch checked="{{isDefault}}" color="#2c4a39" bindchange="onDefaultChange" />
      </view>
    </view>

    <!-- Action Buttons -->
    <view class="action-btn-wrap">
      <button class="save-btn" bindtap="submitSave">保存地址</button>
      <button class="delete-btn" wx:if="{{addressId}}" plain="true" bindtap="submitDelete">删除地址</button>
    </view>

    <view class="scroll-spacer"></view>
  </scroll-view>
</view>
