<view class="phone-page px-page" style="{{pageStyle}}">
  <page-nav title="积分兑换" theme="solid" />

  <view class="px-balance">
    <view class="px-balance__left">
      <view class="px-balance__icon">
        <t-icon name="points" size="36rpx" color="#8b5e22"></t-icon>
      </view>
      <view class="px-balance__meta">
        <text class="px-balance__label">可用积分</text>
        <view class="px-balance__value-row">
          <text class="px-balance__value">{{pointsBalance}}</text>
          <text class="px-balance__unit">分</text>
        </view>
      </view>
    </view>
    <view class="px-balance__tip">
      <text>下单可得积分</text>
      <text>积分兑券立减</text>
    </view>
  </view>

  <view class="px-head">
    <view class="px-head__main">
      <text class="px-head__title">兑换好物</text>
      <text class="px-head__sub">共 {{pointsGoods.length}} 件可兑权益</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="px-state">
    <text class="px-state__title">{{loadingText}}</text>
    <text class="px-state__desc">正在同步可兑换内容</text>
  </view>

  <view wx:elif="{{!pointsGoods.length}}" class="px-state">
    <view class="px-state__icon">
      <t-icon name="gift" size="52rpx" color="#c7bfa8"></t-icon>
    </view>
    <text class="px-state__title">暂无可兑换商品</text>
    <text class="px-state__desc">平台还在补充积分权益，过一会再来看看</text>
  </view>

  <view wx:else class="px-grid">
    <view
      wx:for="{{pointsGoods}}"
      wx:key="id"
      class="px-card {{item.received ? 'px-card--done' : ''}} {{!item.received && !item.canRedeem ? 'px-card--lack' : ''}}"
    >
      <view class="px-card__cover" style="{{item.imageStyle}}">
        <view wx:if="{{!item.imageStyle}}" class="px-card__cover-fallback">
          <t-icon name="gift" size="48rpx" color="#9a8660"></t-icon>
        </view>
        <view class="px-card__tag {{item.received ? 'px-card__tag--done' : item.canRedeem ? 'px-card__tag--avail' : 'px-card__tag--lack'}}">
          {{item.received ? '已兑换' : item.canRedeem ? '可兑换' : '积分不足'}}
        </view>
      </view>
      <view class="px-card__body">
        <text class="px-card__title">{{item.title}}</text>
        <text class="px-card__desc">{{item.desc}}</text>
        <view class="px-card__foot">
          <view class="px-card__cost">
            <t-icon name="points" size="22rpx" color="#c65f2d"></t-icon>
            <text class="px-card__cost-num">{{item.pointsCost}}</text>
          </view>
          <view
            class="px-card__btn {{item.received || !item.canRedeem ? 'px-card__btn--disabled' : ''}}"
            data-coupon-id="{{item.couponId}}"
            bindtap="redeemPoints"
          >
            {{item.received ? '已兑' : item.canRedeem ? '兑换' : '不足'}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="px-safe"></view>
</view>
