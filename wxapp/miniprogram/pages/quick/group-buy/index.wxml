<view class="phone-page phf-near" style="{{pageStyle}}">
  <view class="phf-near__top">
    <page-nav title="{{pageTitle}}" theme="transparent" />
    <view class="phf-near__hint">
      <text class="phf-near__hint-title">附近正在拼</text>
      <text class="phf-near__hint-desc">跟团更省，满员成团即享拼团价</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="phf-near__empty">
    <text>正在加载附近拼单…</text>
  </view>
  <view wx:elif="{{!products.length}}" class="phf-near__empty">
    <text class="phf-near__empty-title">暂无附近拼单</text>
    <text class="phf-near__empty-desc">可以回去开一个新团</text>
  </view>

  <scroll-view wx:else class="phf-near__list" scroll-y enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{products}}"
      wx:key="groupId"
      class="phf-near-item"
      data-product-id="{{item.productId}}"
      data-sku-id="{{item.skuId}}"
      data-group-id="{{item.groupId}}"
      catchtap="joinGroup"
    >
      <view class="phf-near-item__cover">
        <image wx:if="{{item.coverUrl}}" class="phf-near-item__img" src="{{item.coverUrl}}" mode="aspectFill" />
        <view wx:else class="phf-near-item__img {{item.imageClass}}"></view>
        <text class="phf-near-item__remain">还差{{item.remain}}人</text>
      </view>
      <view class="phf-near-item__main">
        <text class="phf-near-item__title">{{item.title}}</text>
        <text class="phf-near-item__area">{{item.area}}</text>
        <view class="phf-near-item__progress">
          <view class="phf-near-item__bar">
            <view class="phf-near-item__fill" style="width: {{item.percent}}%;"></view>
          </view>
          <text class="phf-near-item__members">{{item.memberCount}}/{{item.needed}}人</text>
        </view>
        <view class="phf-near-item__foot">
          <view class="phf-near-item__price-wrap">
            <text class="phf-near-item__yen">¥</text>
            <text class="phf-near-item__price">{{item.groupPrice}}</text>
            <text class="phf-near-item__old">¥{{item.originPrice}}</text>
          </view>
          <button
            class="phf-near-item__btn"
            data-product-id="{{item.productId}}"
            data-sku-id="{{item.skuId}}"
            data-group-id="{{item.groupId}}"
            catchtap="joinGroup"
          >去跟团</button>
        </view>
      </view>
    </view>
    <view class="safe-bottom"></view>
  </scroll-view>
</view>
