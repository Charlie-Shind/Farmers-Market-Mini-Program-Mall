<view class="phone-page phf" style="{{pageStyle}}">
  <!-- 仅导航 + 顶部操作行固定 -->
  <view class="phf__top">
    <page-nav title="拼好货" theme="transparent" />

    <view class="phf-hero">
      <text class="phf-hero__tag">邻里一起拼 · 更省更鲜</text>
      <view class="phf-hero__actions">
        <view class="phf-hero__chip" bindtap="openInviteSheet" hover-class="phf-hero__chip--hover">填邀请码</view>
        <view class="phf-hero__chip phf-hero__chip--ghost" bindtap="onMyGroups" hover-class="phf-hero__chip--hover">我的拼团</view>
      </view>
    </view>
  </view>

  <scroll-view class="phf__body" scroll-y enhanced show-scrollbar="{{false}}" scroll-into-view="{{scrollIntoView}}">
    <!-- 附近实时拼单滚动条 -->
    <view wx:if="{{tickerText}}" class="phf-ticker">
      <text class="phf-ticker__dot">拼</text>
      <text class="phf-ticker__text">{{tickerText}}</text>
    </view>

    <!-- 附近正在拼 -->
    <scroll-view
      wx:if="{{nearbyGroups.length}}"
      class="phf-nearby"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
    >
      <view
        wx:for="{{nearbyGroups}}"
        wx:key="groupId"
        class="phf-nearby__card"
        data-product-id="{{item.productId}}"
        data-sku-id="{{item.skuId}}"
        data-group-id="{{item.groupId}}"
        catchtap="joinExistingGroup"
      >
        <view class="phf-nearby__img-wrap">
          <image wx:if="{{item.coverUrl}}" class="phf-nearby__img" src="{{item.coverUrl}}" mode="aspectFill" />
          <view wx:else class="phf-nearby__img phf-nearby__img--empty"></view>
          <text class="phf-nearby__need">差{{item.remain}}人</text>
        </view>
        <text class="phf-nearby__title">{{item.title}}</text>
        <view class="phf-nearby__row">
          <text class="phf-nearby__price">¥{{item.groupPrice}}</text>
          <text class="phf-nearby__cta">跟团</text>
        </view>
        <text class="phf-nearby__area">{{item.area}}</text>
      </view>
    </scroll-view>

    <!-- 我正在拼的团 -->
    <view wx:if="{{myOngoingGroups.length}}" class="phf-mine">
      <view class="phf-mine__head">
        <text class="phf-mine__title">我正在拼的团</text>
        <text class="phf-mine__more" bindtap="onMyGroups">全部</text>
      </view>
      <swiper
        class="phf-mine__swiper"
        circular="{{myOngoingGroups.length > 1}}"
        indicator-dots="{{myOngoingGroups.length > 1}}"
        indicator-color="rgba(44,74,57,0.18)"
        indicator-active-color="#2c4a39"
        autoplay="{{false}}"
      >
        <swiper-item wx:for="{{myOngoingGroups}}" wx:key="groupId">
          <view class="phf-progress">
            <view class="phf-progress__row">
              <text class="phf-progress__label">拼团进度 {{item.progressText}}</text>
              <view class="phf-progress__timer">
                <text class="phf-progress__timer-label">剩余时间</text>
                <text class="phf-progress__timer-value">{{item.remainText}}</text>
              </view>
            </view>
            <view class="phf-progress__members">
              <view
                wx:for="{{item.members}}"
                wx:for-item="member"
                wx:key="key"
                class="phf-progress__member {{member.filled ? '' : 'is-empty'}}"
              >
                <view class="phf-progress__avatar {{member.filled ? 'is-filled' : ''}} {{member.isMine ? 'is-mine' : ''}}">
                  <image wx:if="{{member.avatarUrl}}" class="phf-progress__avatar-img" src="{{member.avatarUrl}}" mode="aspectFill" />
                </view>
                <text class="phf-progress__role">{{member.label}}</text>
              </view>
            </view>
            <button
              class="phf-progress__btn"
              open-type="share"
              data-group-id="{{item.groupId}}"
              data-invite-code="{{item.inviteCode}}"
              data-title="{{item.title}}"
              catchtap="prepareShare"
            >邀请好友参团</button>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 分类 -->
    <scroll-view id="phf-products" class="phf-cats" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{categoryTabs}}"
        wx:key="key"
        class="phf-cat {{activeCategory === item.key ? 'is-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="selectCategory"
      >
        <text>{{item.label}}</text>
      </view>
    </scroll-view>

    <view wx:if="{{loading}}" class="phf-empty">
      <text>正在加载拼团好物…</text>
    </view>
    <view wx:elif="{{!displayProducts.length}}" class="phf-empty">
      <text class="phf-empty__title">暂无拼团商品</text>
      <text class="phf-empty__desc">切换分类或稍后再来看看</text>
    </view>

    <view wx:else class="phf-list">
      <view
        wx:for="{{displayProducts}}"
        wx:key="productId"
        class="phf-item"
        data-product-id="{{item.productId}}"
        bindtap="openProductDetail"
      >
        <view class="phf-item__cover">
          <image wx:if="{{item.coverUrl}}" class="phf-item__img" src="{{item.coverUrl}}" mode="aspectFill" />
          <view wx:else class="phf-item__img {{item.imageClass}}"></view>
          <text wx:if="{{item.badge}}" class="phf-item__badge">{{item.badge}}</text>
        </view>
        <view class="phf-item__main">
          <text class="phf-item__title">{{item.title}}</text>
          <text class="phf-item__sub">{{item.subtitle}}</text>
          <view class="phf-item__social">
            <text class="phf-item__need">{{item.needText}}</text>
          </view>
          <view class="phf-item__foot">
            <view class="phf-item__price-wrap">
              <text class="phf-item__yen">¥</text>
              <text class="phf-item__price">{{item.groupPrice}}</text>
              <text class="phf-item__old">¥{{item.originPrice}}</text>
            </view>
            <button
              class="phf-item__btn"
              data-product-id="{{item.productId}}"
              data-sku-id="{{item.skuId}}"
              catchtap="joinGroup"
            >去拼单</button>
          </view>
        </view>
      </view>

      <view class="phf-more" bindtap="loadMore">
        <text>查看附近更多拼单</text>
        <t-icon name="chevronRight" size="22rpx" color="#999999"></t-icon>
      </view>
      <view class="phf-list__pad"></view>
    </view>
  </scroll-view>

  <!-- 底部栏 -->
  <view class="phf-dock">
    <view class="phf-dock__btn" bindtap="onRule">
      <t-icon name="origin" size="34rpx" color="#666666"></t-icon>
      <text>规则</text>
    </view>
    <view class="phf-dock__btn" bindtap="openInviteSheet">
      <t-icon name="gift" size="34rpx" color="#666666"></t-icon>
      <text>邀请码</text>
    </view>
    <view class="phf-dock__btn" bindtap="onMyGroups">
      <t-icon name="group" size="34rpx" color="#666666"></t-icon>
      <text>我的拼团</text>
    </view>
    <view class="phf-dock__cta" bindtap="scrollToProducts">
      <text>立即开团更优惠</text>
    </view>
  </view>

  <!-- 邀请码弹窗 -->
  <view wx:if="{{showInviteSheet}}" class="phf-sheet" bindtap="closeInviteSheet">
    <view class="phf-sheet__panel" catchtap="noop">
      <view class="phf-sheet__head">
        <text class="phf-sheet__title">输入邀请码</text>
        <text class="phf-sheet__close" bindtap="closeInviteSheet">×</text>
      </view>
      <text class="phf-sheet__desc">输入好友分享的 6 位邀请码，快速加入正在进行的拼团。</text>
      <view class="phf-sheet__field">
        <input
          class="phf-sheet__input"
          value="{{inviteCodeInput}}"
          placeholder="请输入 6 位邀请码"
          maxlength="6"
          bindinput="onInviteCodeInput"
          bindconfirm="confirmInviteCode"
        />
      </view>
      <view class="phf-sheet__actions">
        <button class="phf-sheet__btn phf-sheet__btn--ghost" bindtap="closeInviteSheet">取消</button>
        <button class="phf-sheet__btn phf-sheet__btn--primary" bindtap="confirmInviteCode">查找拼团</button>
      </view>
    </view>
  </view>
</view>
