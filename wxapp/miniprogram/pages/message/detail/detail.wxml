<view class="phone-page message-detail-page" style="{{pageStyle}}">
  <view class="board-head">
    <view class="page-title-bar">
      <button class="back-btn" bindtap="goBack" hover-class="back-btn--hover">
        <t-icon name="back" size="48rpx" color="#ffffff"></t-icon>
      </button>
      <text class="page-title-bar__title">公告详情</text>
      <text></text>
    </view>
  </view>

  <view wx:if="{{message}}" class="detail-card">
    <view class="detail-hero {{toneClass}}">
      <view class="detail-hero__top">
        <text class="detail-badge">{{message.typeLabel}}</text>
        <text class="detail-status">{{message.isRead ? '已读' : '未读'}}</text>
      </view>
      <text class="detail-title">{{message.title}}</text>
      <text class="detail-time">{{publishTimeText}}</text>
    </view>

    <view class="detail-body">
      <view wx:for="{{blocks}}" wx:key="index" class="detail-block">
        <text wx:if="{{item.type === 'text'}}" class="detail-text">{{item.value}}</text>
        <view wx:elif="{{item.type === 'image'}}" class="detail-image-wrap" bindtap="previewImage" data-url="{{item.url}}">
          <image class="detail-image" src="{{item.url}}" mode="widthFix"></image>
          <text wx:if="{{item.alt}}" class="detail-image__alt">{{item.alt}}</text>
        </view>
      </view>

    </view>
  </view>

  <view wx:elif="{{loading}}" class="empty-state">
    <text class="empty-state__title">加载中…</text>
    <text class="empty-state__desc">正在获取公告详情，请稍候。</text>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-state__title">公告不存在</text>
    <text class="empty-state__desc">可能已被删除或链接失效。</text>
  </view>

  <view class="safe-bottom"></view>
</view>
