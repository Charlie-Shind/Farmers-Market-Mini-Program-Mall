<view class="phone-page history-page" style="{{pageStyle}}">
  <page-nav title="消息" theme="solid">
    <button
      wx:if="{{totalUnread > 0}}"
      slot="right"
      class="read-btn"
      bindtap="clearUnread"
      disabled="{{loadingAction}}"
    >全部已读</button>
  </page-nav>

  <scroll-view
    scroll-y="true"
    class="history-scroll"
    enhanced="true"
    show-scrollbar="{{false}}"
    bindscrolltolower="loadMore"
  >
    <view wx:if="{{groups.length > 0}}" class="history-list">
      <view
        wx:for="{{groups}}"
        wx:key="key"
        wx:for-index="cardIndex"
        class="history-item"
      >
        <text class="history-item__time">{{item.latestTimeText}}</text>

        <view
          class="notice-card"
          data-type="{{item.type}}"
          data-type-label="{{item.typeLabel}}"
          bindtap="openConversation"
        >
          <view class="notice-card__header">
            <view class="notice-avatar">
              <image
                wx:if="{{item.showAvatarImage}}"
                class="notice-avatar__img"
                src="{{item.avatarSrc}}"
                mode="aspectFill"
                data-index="{{cardIndex}}"
                binderror="handleAvatarError"
              ></image>
              <t-icon wx:else name="{{item.fallbackIconName}}" size="32rpx" opacity="0.9"></t-icon>
            </view>
            <text class="notice-name">{{item.typeLabel}}</text>
            <view class="notice-more">
              <text></text>
              <text></text>
              <text></text>
            </view>
          </view>

          <view class="notice-card__body">
            <text class="notice-title">{{item.latestTitle}}</text>
            <text wx:if="{{item.showSummary}}" class="notice-summary">{{item.latestSummary}}</text>
          </view>

          <view class="notice-card__footer">
            <view class="notice-footer-left">
              <text class="notice-footer-name">{{footerName}}</text>
            </view>
            <view class="notice-footer-right">
              <text class="notice-footer-type">{{footerType}}</text>
              <t-icon name="chevronRight" size="22rpx" opacity="0.45"></t-icon>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-state__text">{{loading ? '加载中' : emptyText}}</text>
    </view>

    <view wx:if="{{groups.length}}" class="load-more">
      <text wx:if="{{loadingMore}}">加载中</text>
      <text wx:elif="{{noMore}}">已到底</text>
    </view>

    <view class="scroll-spacer"></view>
  </scroll-view>
</view>
