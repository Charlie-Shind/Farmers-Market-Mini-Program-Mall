<view class="phone-page msg-page" style="{{pageStyle}}">
  <view class="msg-page__top">
    <page-nav title="消息" theme="solid">
      <button
        wx:if="{{totalUnread > 0}}"
        slot="right"
        class="msg-read-btn"
        bindtap="clearUnread"
        disabled="{{loadingAction}}"
      >全部已读</button>
    </page-nav>

    <view class="msg-hero">
      <view class="msg-hero__copy">
        <text class="msg-hero__eyebrow">湾源农仓 · 消息中心</text>
        <text class="msg-hero__title">服务通知与官方公告</text>
        <text class="msg-hero__desc">产地动态、订单进度与活动提醒，一处查收</text>
      </view>
      <view class="msg-hero__stat {{totalUnread > 0 ? 'is-hot' : ''}}">
        <text class="msg-hero__stat-num">{{totalUnread}}</text>
        <text class="msg-hero__stat-label">未读</text>
      </view>
    </view>

    <scroll-view class="msg-channels" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{channels}}"
        wx:key="key"
        class="msg-channel {{activeChannel === item.key ? 'is-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="selectChannel"
      >
        <view class="msg-channel__icon msg-channel__icon--{{item.tone}}">
          <t-icon name="{{item.icon}}" size="28rpx" color="{{item.iconColor}}"></t-icon>
        </view>
        <text class="msg-channel__label">{{item.label}}</text>
        <text wx:if="{{item.unread > 0}}" class="msg-channel__badge">{{item.unread > 99 ? '99+' : item.unread}}</text>
      </view>
    </scroll-view>
  </view>

  <scroll-view
    scroll-y
    class="msg-scroll"
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="loadMore"
  >
    <view wx:if="{{displayMessages.length}}" class="msg-list">
      <view
        wx:for="{{displayMessages}}"
        wx:key="receiptId"
        class="msg-card {{item.isRead ? '' : 'is-unread'}}"
        data-receipt-id="{{item.receiptId}}"
        bindtap="openMessage"
      >
        <view class="msg-card__accent msg-card__accent--{{item.tone}}"></view>

        <view class="msg-card__icon">
          <image
            class="msg-card__img"
            src="{{item.avatarSrc || icons.defaultAvatar}}"
            mode="aspectFill"
          />
          <view wx:if="{{!item.isRead}}" class="msg-card__dot"></view>
        </view>

        <view class="msg-card__main">
          <view class="msg-card__head">
            <text class="msg-card__type">{{item.typeLabel}}</text>
            <text class="msg-card__time">{{item.timeText}}</text>
          </view>
          <text class="msg-card__title">{{item.title}}</text>
          <text wx:if="{{item.showSummary}}" class="msg-card__summary">{{item.summary}}</text>
          <view class="msg-card__foot">
            <view class="msg-card__brand">
              <view class="msg-card__brand-mark"></view>
              <text>{{footerName}}</text>
            </view>
            <view class="msg-card__meta">
              <text wx:if="{{!item.isRead}}" class="msg-card__unread">未读</text>
              <text class="msg-card__cta">查看</text>
              <t-icon name="chevronRight" size="22rpx" color="#8a877f"></t-icon>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{!loading}}" class="msg-empty">
      <view class="msg-empty__orb">
        <t-icon name="bell" size="64rpx" color="#2c4a39"></t-icon>
      </view>
      <text class="msg-empty__title">{{emptyText}}</text>
      <text class="msg-empty__desc">官方公告、系统通知与订单消息会在这里呈现</text>
    </view>

    <view wx:if="{{loading}}" class="msg-loading">
      <text>正在同步消息…</text>
    </view>

    <view wx:if="{{displayMessages.length && (loadingMore || noMore)}}" class="msg-end">
      <view class="msg-end__line"></view>
      <text wx:if="{{loadingMore}}">加载中</text>
      <text wx:else>已经到底了</text>
      <view class="msg-end__line"></view>
    </view>

    <view class="msg-spacer"></view>
  </scroll-view>
</view>
