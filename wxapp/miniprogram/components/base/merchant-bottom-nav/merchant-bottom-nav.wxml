<view class="bottom-nav merchant-bottom-nav">
  <view
    wx:for="{{items}}"
    wx:key="key"
    class="bottom-nav__item {{activeKey === item.key ? 'bottom-nav__item--active' : ''}}"
    data-url="{{item.url}}"
    data-key="{{item.key}}"
    bindtap="go"
  >
    <t-icon
      name="{{item.icon}}"
      size="48rpx"
      color="{{activeKey === item.key ? '#2C4A39' : '#8A877F'}}"
      opacity="{{activeKey === item.key ? 1 : 0.68}}"
    ></t-icon>
    <text class="bottom-nav__label">{{item.label}}</text>
  </view>
</view>
