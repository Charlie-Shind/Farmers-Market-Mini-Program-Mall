@import "./tokens.wxss";

* { box-sizing: border-box; }

page { font-family: var(--font-body); color: var(--color-text); background: var(--color-bg); }
button, input, textarea, select { font: inherit; color: inherit; }
button { border: 0; background: none; padding: 0; cursor: pointer; }
a { color: inherit; text-decoration: none; }
img { display: block; }
.icon { width: var(--icon-size); height: var(--icon-size); display: inline-block; color: currentColor; }
.icon-sm { width: 36rpx; height: 36rpx; display: inline-block; color: currentColor; }
.icon-lg { width: 56rpx; height: 56rpx; display: inline-block; color: currentColor; }

.driver-page { max-width: var(--mobile-width); margin: 0 auto; min-height: 100vh; background: var(--color-bg); padding: calc(var(--safe-top) + 24rpx) var(--page-x) 80rpx; }
.driver-title { font-size: var(--font-size-2xl); font-weight: var(--font-weight-black); line-height: 1.15; margin: 0 0 var(--space-3); }
.driver-desc { color: var(--color-text-2); font-size: var(--font-size-sm); line-height: 1.6; margin: 0 0 var(--space-4); }
.driver-group { margin-top: var(--space-5); }
.driver-group h2 { margin: 0 0 var(--space-3); font-size: var(--font-size-base); }
.driver-list { border-top: 2rpx solid var(--color-line-soft); }
.driver-link { min-height: 128rpx; display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); border-bottom: 2rpx solid var(--color-line-soft); }
.driver-link strong { font-size: var(--font-size-md); }
.driver-link small { display: block; margin-top: 8rpx; color: var(--color-muted); font-size: var(--font-size-xs); line-height: 1.4; }
.driver-badge { min-width: 104rpx; text-align: center; height: 52rpx; line-height: 48rpx; border-radius: var(--radius-full); border: 2rpx solid var(--color-line); color: var(--color-primary-strong); background: var(--color-primary-soft); font-size: var(--font-size-xs); font-weight: var(--font-weight-bold); }

.app-page { position: relative; max-width: var(--mobile-width); min-height: 100vh; margin: 0 auto; background: var(--color-bg); padding-bottom: calc(var(--bottom-nav-height) + env(safe-area-inset-bottom)); overflow-x: hidden; }
.app-page.no-bottom { padding-bottom: 56rpx; }
.app-page.with-sticky { padding-bottom: calc(192rpx + env(safe-area-inset-bottom)); }
.status-space { height: var(--safe-top); }
.app-topbar { height: var(--topbar-height); display: flex; align-items: center; gap: var(--space-3); padding: 0 var(--page-x); background: var(--color-bg); }
.back-btn, .icon-btn { width: 80rpx; height: 80rpx; border-radius: var(--radius-full); display: grid; place-items: center; color: var(--color-text); flex: 0 0 auto; }
.icon-action { min-width: 88rpx; min-height: 92rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx; color: var(--color-text); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); }
.search-pill { flex: 1; min-width: 0; height: 88rpx; display: flex; align-items: center; gap: var(--space-2); padding: 0 30rpx; border-radius: var(--radius-full); background: var(--color-surface-soft); color: var(--color-placeholder); }
.search-pill input { flex: 1; min-width: 0; border: 0; outline: 0; background: transparent; font-size: var(--font-size-md); }
.page-titlebar { padding: 20rpx var(--page-x) 16rpx; display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
.title-block { flex: 1; min-width: 0; }
.page-title { font-size: var(--font-size-2xl); font-weight: var(--font-weight-black); line-height: 1.15; letter-spacing: -.02em; }
.page-subtitle { margin-top: 6rpx; color: var(--color-muted); font-size: var(--font-size-sm); }

.tabs { height: var(--tab-height); display: flex; align-items: center; gap: 52rpx; overflow-x: auto; padding: 0 var(--page-x); border-bottom: 2rpx solid var(--color-line-soft); scrollbar-width: none; }
.tabs::-webkit-scrollbar { display: none; }
.tab { position: relative; height: var(--tab-height); display: flex; align-items: center; white-space: nowrap; color: var(--color-text); font-size: var(--font-size-lg); font-weight: var(--font-weight-medium); }
.tab.active { font-weight: var(--font-weight-black); }
.tab.active::after { content: ''; position: absolute; left: 0; right: 0; bottom: 12rpx; height: 14rpx; background: var(--color-primary); z-index: 0; }
.tab span { position: relative; z-index: 1; }
.toolbar { min-height: 92rpx; display: flex; align-items: center; gap: var(--space-3); padding: 0 var(--page-x); border-bottom: 2rpx solid var(--color-line-soft); overflow-x: auto; scrollbar-width: none; }
.toolbar::-webkit-scrollbar { display: none; }
.chip { height: 64rpx; padding: 0 28rpx; border-radius: var(--radius-full); display: inline-flex; align-items: center; justify-content: center; white-space: nowrap; color: var(--color-text-2); background: var(--color-surface-soft); font-size: var(--font-size-sm); font-weight: var(--font-weight-bold); }
.chip.active { color: var(--color-primary-strong); background: var(--color-primary-soft); }

.full-list { width: 100%; background: var(--color-bg); }
.list-empty { display:none; padding: 88rpx var(--page-x); text-align: center; color: var(--color-muted); font-size: var(--font-size-sm); }
.full-list.is-empty .list-empty { display:block; }
.divider { height: 16rpx; background: var(--color-surface-soft); border-top: 2rpx solid var(--color-line-soft); border-bottom: 2rpx solid var(--color-line-soft); }
.load-more { padding: 36rpx var(--page-x); text-align: center; color: var(--color-placeholder); font-size: var(--font-size-sm); }
.avatar { width: var(--avatar-size); height: var(--avatar-size); border-radius: var(--radius-full); object-fit: cover; background: var(--color-surface-soft); flex: 0 0 auto; }
.avatar.lg { width: var(--avatar-lg); height: var(--avatar-lg); }
.goods-img { width: var(--thumb-size); height: var(--thumb-size); border-radius: 20rpx; object-fit: cover; background: var(--color-surface-soft); flex: 0 0 auto; }
.goods-img.sm { width: var(--thumb-sm); height: var(--thumb-sm); border-radius: 16rpx; }
.status-text { color: var(--color-warning); font-size: var(--font-size-md); font-weight: var(--font-weight-bold); white-space: nowrap; }
.status-text.success { color: var(--color-primary-strong); }
.status-text.danger { color: var(--color-danger); }
.status-pill { min-height: 52rpx; display: inline-flex; align-items: center; border-radius: var(--radius-full); padding: 0 20rpx; font-size: var(--font-size-xs); font-weight: var(--font-weight-bold); white-space: nowrap; }
.status-pill.success { color: var(--color-primary-strong); background: var(--color-primary-soft); }
.status-pill.warning { color: var(--color-warning); background: var(--color-warning-soft); }
.status-pill.danger { color: var(--color-danger); background: var(--color-danger-soft); }
.status-pill.info { color: var(--color-secondary); background: var(--color-secondary-soft); }

.order-item { padding: 36rpx var(--page-x) 32rpx; border-bottom: 2rpx solid var(--color-line-soft); background: var(--color-bg); }
.buyer-row { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); margin-bottom: 28rpx; }
.buyer-info { min-width: 0; display: flex; align-items: center; gap: var(--space-3); }
.buyer-name { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: var(--font-size-lg); font-weight: var(--font-weight-bold); }
.product-row { display: grid; grid-template-columns: var(--thumb-size) minmax(0,1fr) auto; gap: 24rpx; align-items: start; }
.product-main { min-width: 0; }
.product-title { font-size: var(--font-size-base); line-height: 1.42; color: var(--color-text); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.product-sub { margin-top: 12rpx; color: var(--color-muted); font-size: var(--font-size-sm); line-height: 1.35; }
.product-price { font-size: var(--font-size-lg); font-weight: var(--font-weight-black); white-space: nowrap; padding-left: 4rpx; }
.item-actions { min-height: 92rpx; display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); margin-top: 32rpx; }
.more-link { color: var(--color-placeholder); font-size: var(--font-size-base); }
.btn-row { display: flex; align-items: center; gap: 20rpx; }
.pill-btn { height: var(--button-height-sm); min-width: 156rpx; padding: 0 30rpx; display: inline-flex; align-items: center; justify-content: center; border-radius: var(--radius-full); background: var(--color-surface-soft); color: var(--color-text); font-size: var(--font-size-md); font-weight: var(--font-weight-bold); white-space: nowrap; }
.pill-btn.primary { background: var(--color-primary); color: var(--color-white); }
.pill-btn.warning { background: var(--color-warning); color: var(--color-white); }
.pill-btn.outline { border: 2rpx solid var(--color-line); background: var(--color-bg); }
.pill-btn.danger { color: var(--color-danger); background: var(--color-danger-soft); }

.product-list-item { padding: 32rpx var(--page-x); display: grid; grid-template-columns: var(--thumb-size) minmax(0,1fr); gap: 24rpx; border-bottom: 2rpx solid var(--color-line-soft); background: var(--color-bg); }
.product-list-body { min-width: 0; }
.product-list-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; margin-bottom: 12rpx; }
.product-list-title { min-width: 0; font-size: var(--font-size-base); font-weight: var(--font-weight-bold); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.product-list-meta { color: var(--color-muted); font-size: var(--font-size-sm); line-height: 1.5; }
.product-list-bottom { margin-top: 24rpx; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }
.price-main { color: var(--color-text); font-size: var(--font-size-lg); font-weight: var(--font-weight-black); }
.entry-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 2rpx solid var(--color-line-soft); border-bottom: 2rpx solid var(--color-line-soft); }
.entry-item { min-height: 164rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; color: var(--color-text); font-size: var(--font-size-sm); font-weight: var(--font-weight-medium); }
.entry-item .icon { color: var(--color-primary-strong); }
.metric-strip { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 2rpx solid var(--color-line-soft); border-bottom: 2rpx solid var(--color-line-soft); }
.metric-item { min-height: 156rpx; display: flex; flex-direction: column; justify-content: center; padding: 0 var(--page-x); border-right: 2rpx solid var(--color-line-soft); }
.metric-item:last-child { border-right: 0; }
.metric-value { font-size: var(--font-size-xl); font-weight: var(--font-weight-black); line-height: 1.1; }
.metric-label { margin-top: 14rpx; color: var(--color-muted); font-size: var(--font-size-xs); }
.section-line-title { padding: 36rpx var(--page-x) 20rpx; font-size: var(--font-size-base); font-weight: var(--font-weight-black); display: flex; align-items: center; justify-content: space-between; }
.notice-row, .setting-row, .finance-row, .message-row { min-height: 136rpx; padding: 26rpx var(--page-x); display: flex; align-items: center; justify-content: space-between; gap: 24rpx; border-bottom: 2rpx solid var(--color-line-soft); background: var(--color-bg); }
.row-main { min-width: 0; }
.row-title { font-size: var(--font-size-base); font-weight: var(--font-weight-bold); line-height: 1.35; }
.row-desc { margin-top: 8rpx; color: var(--color-muted); font-size: var(--font-size-sm); line-height: 1.4; }
.row-right { flex: 0 0 auto; display: inline-flex; align-items: center; gap: 12rpx; color: var(--color-muted); font-size: var(--font-size-sm); }

.form-section { padding: 36rpx var(--page-x); border-bottom: 16rpx solid var(--color-surface-soft); }
.form-section-title { margin-bottom: 28rpx; font-size: var(--font-size-base); font-weight: var(--font-weight-black); display:flex; align-items:center; justify-content:space-between; }
.field { margin-bottom: 28rpx; }
.field:last-child { margin-bottom: 0; }
.field-label { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14rpx; color: var(--color-text-2); font-size: var(--font-size-sm); font-weight: var(--font-weight-bold); }
.field input, .field textarea, .field select { width: 100%; border: 2rpx solid var(--color-line); background: var(--color-bg); border-radius: var(--radius-md); outline: 0; }
.field input, .field select { height: var(--input-height); padding: 0 28rpx; }
.field textarea { min-height: 196rpx; resize: vertical; padding: 24rpx 28rpx; line-height: 1.55; }
.field-inline { display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.image-uploader { display:grid; grid-template-columns: repeat(4,1fr); gap:20rpx; }
.upload-tile { aspect-ratio: 1; border-radius: 24rpx; background: var(--color-surface-soft); display:grid; place-items:center; color: var(--color-muted); border:2rpx dashed var(--color-line); }
.spec-row { display:grid; grid-template-columns: 1fr 176rpx 144rpx; gap:16rpx; align-items:center; margin-bottom:20rpx; }
.spec-row input { height:80rpx; border:2rpx solid var(--color-line); border-radius:20rpx; padding:0 20rpx; }
.bottom-actions { position: fixed; left: 50%; bottom: 0; width: 100%; max-width: var(--mobile-width); transform: translateX(-50%); padding: 24rpx var(--page-x) calc(24rpx + env(safe-area-inset-bottom)); display: flex; gap: 24rpx; background: var(--color-bg); border-top: 2rpx solid var(--color-line-soft); z-index: 20; }
.action-btn { flex: 1; height: var(--button-height); border-radius: var(--radius-full); background: var(--color-primary); color: var(--color-white); font-weight: var(--font-weight-black); font-size: var(--font-size-base); }
.action-btn.secondary { background: var(--color-surface-soft); color: var(--color-text); }
.action-btn.danger { background: var(--color-danger-soft); color: var(--color-danger); }
.bottom-nav { position: fixed; left: 50%; bottom: 0; transform: translateX(-50%); width: 100%; max-width: var(--mobile-width); height: calc(var(--bottom-nav-height) + env(safe-area-inset-bottom)); padding-bottom: env(safe-area-inset-bottom); display: grid; grid-template-columns: repeat(5, 1fr); background: var(--color-bg); border-top: 2rpx solid var(--color-line-soft); z-index: 20; }
.bottom-nav a { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; color: var(--color-muted); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); }
.bottom-nav a.active { color: var(--color-primary-strong); font-weight: var(--font-weight-bold); }
.bottom-nav .icon { width: 44rpx; height: 44rpx; }

.sheet-mask { position: fixed; inset: 0; max-width: var(--mobile-width); margin: 0 auto; background: var(--color-mask); opacity: 0; pointer-events: none; transition: .18s ease; z-index: 40; }
.sheet-mask.show { opacity: 1; pointer-events: auto; }
.sheet { position: fixed; left: 50%; bottom: 0; width: 100%; max-width: var(--mobile-width); transform: translate(-50%, 105%); background: var(--color-bg); border-radius: var(--radius-xl) var(--radius-xl) 0 0; box-shadow: var(--shadow-float); padding: 36rpx var(--page-x) calc(36rpx + env(safe-area-inset-bottom)); transition: .22s ease; z-index: 41; }
.sheet.show { transform: translate(-50%, 0); }
.sheet-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:32rpx; }
.sheet-title { font-size: var(--font-size-lg); font-weight: var(--font-weight-black); }
.sheet-group { margin-bottom: 32rpx; }
.sheet-label { color: var(--color-muted); font-size: var(--font-size-sm); font-weight: var(--font-weight-bold); margin-bottom: 16rpx; }
.option-grid { display:flex; flex-wrap:wrap; gap:20rpx; }
.option { min-height:68rpx; padding:0 26rpx; border-radius: var(--radius-full); background:var(--color-surface-soft); color:var(--color-text-2); font-size:var(--font-size-sm); font-weight:var(--font-weight-bold); display:inline-flex; align-items:center; }
.option.active { color:var(--color-primary-strong); background:var(--color-primary-soft); }
.toast { position: fixed; left: 50%; bottom: 180rpx; transform: translateX(-50%); min-width: 300rpx; max-width: 82%; padding: 20rpx 28rpx; border-radius: var(--radius-full); background: var(--color-text); color: var(--color-white); text-align:center; font-size: var(--font-size-sm); opacity: 0; pointer-events:none; transition:.18s ease; z-index:60; }
.toast.show { opacity: 1; }
.hidden { display: none !important; }

.chat-screen { padding: 24rpx var(--page-x); background: var(--color-surface-soft); min-height: calc(100vh - 280rpx); }
.bubble { max-width: 78%; padding: 20rpx 24rpx; border-radius: 28rpx; margin-bottom: 24rpx; font-size: var(--font-size-md); line-height:1.45; background: var(--color-bg); }
.bubble.me { margin-left:auto; background: var(--color-primary-soft); }
.input-bar { position:fixed; left:50%; bottom:0; transform:translateX(-50%); max-width:var(--mobile-width); width:100%; display:flex; gap:16rpx; padding:24rpx var(--page-x) calc(24rpx + env(safe-area-inset-bottom)); background:var(--color-bg); border-top:2rpx solid var(--color-line-soft); }
.input-bar input { flex:1; height:84rpx; border:2rpx solid var(--color-line); border-radius:var(--radius-full); padding:0 28rpx; outline:0; }


/* ===== V4 Visual Refinement ===== */
page { background: var(--color-bg-warm); }
.app-page { background: var(--color-bg); }
.search-pill { background: var(--color-bg-subtle); border: 2rpx solid var(--color-line-soft); }
.tab.active::after { background: var(--color-warning); }
.chip.active { color: var(--color-primary-strong); background: var(--color-primary-soft); }
.pill-btn.primary, .action-btn { background: var(--color-primary); }
.pill-btn.warning { background: var(--color-accent); color: var(--color-white); }
.status-pill.success { color: var(--color-success); background: var(--color-success-soft); }
.status-pill.warning { color: #B66A21; background: var(--color-warning-soft); }
.status-pill.danger { color: var(--color-danger); background: var(--color-danger-soft); }
.status-pill.info { color: var(--color-secondary); background: var(--color-secondary-soft); }
.price-main, .product-price { color: var(--color-primary-strong); }
.section-note { padding: 0 var(--page-x) 28rpx; color: var(--color-muted); font-size: var(--font-size-sm); line-height: 1.55; border-bottom: 2rpx solid var(--color-line-soft); }
.activity-card { padding: 32rpx var(--page-x); border-bottom: 2rpx solid var(--color-line-soft); background: var(--color-bg); }
.activity-top { display:flex; align-items:center; justify-content:space-between; gap:24rpx; margin-bottom:24rpx; }
.activity-name { font-size: var(--font-size-lg); font-weight: var(--font-weight-black); line-height:1.3; }
.activity-meta { margin-top:8rpx; color:var(--color-muted); font-size:var(--font-size-sm); }
.activity-body { display:grid; grid-template-columns: 144rpx 1fr; gap:24rpx; align-items:start; }
.activity-cover { width:144rpx; height:144rpx; border-radius:24rpx; overflow:hidden; background:var(--color-surface-soft); }
.activity-cover img { width:100%; height:100%; object-fit:cover; }
.activity-progress { margin-top:20rpx; }
.progress-line { height:14rpx; border-radius:1998rpx; background:var(--color-line-soft); overflow:hidden; }
.progress-line i { display:block; height:100%; width:var(--v, 50%); background:var(--color-accent); border-radius:1998rpx; }
.progress-label { margin-top:12rpx; display:flex; justify-content:space-between; color:var(--color-muted); font-size:var(--font-size-xs); }
.activity-actions { margin-top:28rpx; display:flex; align-items:center; justify-content:space-between; gap:20rpx; }
.activity-actions .btn-row { margin-left:auto; }
.rule-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:20rpx; }
.rule-tile { min-height:144rpx; padding:22rpx; border-radius:28rpx; background:var(--color-bg-subtle); border:2rpx solid var(--color-line-soft); }
.rule-tile strong { display:block; color:var(--color-primary-strong); font-size:34rpx; }
.rule-tile span { display:block; margin-top:12rpx; color:var(--color-muted); font-size:22rpx; line-height:1.3; }
.timeline { padding: 12rpx var(--page-x) 36rpx; }
.timeline-row { position:relative; padding: 20rpx 0 20rpx 48rpx; border-left:4rpx solid var(--color-line-soft); margin-left:14rpx; }
.timeline-row::before { content:''; position:absolute; left:-12rpx; top:32rpx; width:20rpx; height:20rpx; border-radius:50%; background:var(--color-primary); }
.timeline-row strong { display:block; font-size:var(--font-size-md); }
.timeline-row span { display:block; margin-top:8rpx; color:var(--color-muted); font-size:var(--font-size-sm); line-height:1.45; }
.draft-row { min-height: 172rpx; padding: 28rpx var(--page-x); display:flex; align-items:center; justify-content:space-between; gap:24rpx; border-bottom:2rpx solid var(--color-line-soft); }
.draft-mark { width:88rpx; height:88rpx; border-radius:28rpx; background:var(--color-bg-subtle); color:var(--color-primary); display:grid; place-items:center; flex:0 0 auto; }
.draft-main { flex:1; min-width:0; }
.draft-title { font-weight:var(--font-weight-black); font-size:var(--font-size-base); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.draft-desc { margin-top:10rpx; color:var(--color-muted); font-size:var(--font-size-sm); line-height:1.4; }
.sku-card { margin: 0 0 24rpx; padding: 28rpx; border-radius: 32rpx; background: var(--color-bg-subtle); border: 2rpx solid var(--color-line-soft); }
.sku-head { display:flex; align-items:center; justify-content:space-between; gap:20rpx; margin-bottom:24rpx; }
.sku-name { font-size: var(--font-size-base); font-weight:var(--font-weight-black); }
.sku-grid { display:grid; grid-template-columns: 1fr 1fr; gap:20rpx; }
.sku-field label { display:block; color:var(--color-muted); font-size:22rpx; font-weight:var(--font-weight-bold); margin-bottom:10rpx; }
.sku-field input { width:100%; height:84rpx; border:2rpx solid var(--color-line); border-radius:24rpx; padding:0 24rpx; background:var(--color-bg); outline:0; }
.sku-spec-list { display:flex; flex-wrap:wrap; gap:16rpx; margin-top:16rpx; }
.sku-spec-list .chip { height:60rpx; }
.sticky-mini { position: sticky; top: 0; z-index: 9; background: rgba(255,255,255,.96); backdrop-filter: blur(20rpx); }
