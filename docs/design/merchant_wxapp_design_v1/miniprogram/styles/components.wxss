.sku-input input { width:100%; height:78rpx; border:2rpx solid var(--color-line); border-radius:24rpx; padding:0 20rpx; outline:0; background:var(--color-bg-subtle); font-size:26rpx; }
.form-line { min-height:132rpx; padding: 24rpx var(--page-x); border-bottom:2rpx solid var(--color-line-soft); background:#fff; }
.form-line label { display:flex; align-items:center; justify-content:space-between; gap:20rpx; margin-bottom:16rpx; color:var(--color-muted); font-size:24rpx; font-weight:900; }
.form-line input, .form-line textarea { width:100%; border:0; outline:0; background:transparent; font-size:32rpx; line-height:1.45; }
.form-line textarea { min-height:148rpx; resize:none; }
.photo-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:18rpx; padding: 0 var(--page-x) 32rpx; }
.photo-box { aspect-ratio:1/1; border-radius:28rpx; background:var(--color-bg-subtle); border:2rpx dashed var(--color-line); display:grid; place-items:center; color:var(--color-muted); overflow:hidden; position:relative; }
.photo-box img { width:100%; height:100%; object-fit:cover; }
.photo-box .tag { position:absolute; left:12rpx; top:12rpx; height:44rpx; padding:0 14rpx; border-radius:1998rpx; background:var(--color-primary); color:#fff; font-size:20rpx; font-weight:900; display:flex; align-items:center; }
.product-picker-row { display:grid; grid-template-columns:52rpx 124rpx 1fr auto; gap:20rpx; align-items:center; min-height:176rpx; padding:24rpx var(--page-x); border-bottom:2rpx solid var(--color-line-soft); background:#fff; }
.product-picker-row img { width:124rpx; height:124rpx; border-radius:26rpx; object-fit:cover; background:var(--color-bg-subtle); }
.product-picker-title { font-size:28rpx; font-weight:900; line-height:1.35; }
