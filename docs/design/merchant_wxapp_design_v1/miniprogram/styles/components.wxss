.multi-chip.active { color:var(--color-primary-strong); background:var(--color-primary-soft); border-color:transparent; }
.spec-editor { padding: 0 var(--page-x) 32rpx; border-bottom:2rpx solid var(--color-line-soft); }
.spec-block { padding:28rpx 0; border-bottom:2rpx solid var(--color-line-soft); }
.spec-block:last-child { border-bottom:0; }
.spec-block-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:20rpx; }
.spec-block-title { font-size:30rpx; font-weight:900; }
.spec-option-wrap { display:flex; gap:16rpx; flex-wrap:wrap; }
