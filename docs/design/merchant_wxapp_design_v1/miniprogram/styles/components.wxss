  --color-primary-tint: #F3F7F2;
  --color-accent: #C85F3D;
  --color-accent-strong: #A6462C;
  --color-accent-soft: #FFF1EA;
  --color-bg-warm: #F4EFE5;
  --color-bg-subtle: #FBF7EF;
  --color-line: #E7DDD0;
  --color-line-soft: #F0E7DA;
  --color-text: #22362B;
  --color-text-2: #4E6757;
}
.top-soft { background: linear-gradient(180deg, var(--color-bg-warm) 0%, var(--color-bg) 72%); }
.shop-line { display:flex; align-items:center; justify-content:space-between; gap:24rpx; }
