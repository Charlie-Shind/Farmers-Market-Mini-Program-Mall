.chart-tabs { display:flex; gap:16rpx; }
.chart-tabs .mini-tab { height:56rpx; padding:0 22rpx; border-radius:1998rpx; background:var(--color-bg-subtle); color:var(--color-muted); font-size:24rpx; font-weight:800; display:flex; align-items:center; }
.chart-tabs .mini-tab.active { background:var(--color-primary-soft); color:var(--color-primary-strong); }
.line-chart { height:304rpx; border-radius:36rpx; background:linear-gradient(180deg, var(--color-bg-subtle), #fff); border:2rpx solid var(--color-line-soft); padding:28rpx 24rpx 20rpx; position:relative; overflow:hidden; }
.line-chart svg { width:100%; height:212rpx; display:block; overflow:visible; }
.line-chart .axis { position:absolute; left:24rpx; right:24rpx; bottom:16rpx; display:grid; grid-template-columns:repeat(7,1fr); color:var(--color-muted); font-size:22rpx; text-align:center; }
.stat-card-row { display:grid; grid-template-columns:repeat(3,1fr); border-bottom:2rpx solid var(--color-line-soft); }
.stat-cell { padding:30rpx var(--space-3); min-height:144rpx; }
.stat-cell + .stat-cell { border-left:2rpx solid var(--color-line-soft); }
.stat-cell strong { display:block; font-size:38rpx; line-height:1.1; font-weight:900; color:var(--color-primary-strong); }
.stat-cell span { display:block; margin-top:12rpx; color:var(--color-muted); font-size:24rpx; }
.workbench-grid { display:grid; grid-template-columns:repeat(4,1fr); border-top:2rpx solid var(--color-line-soft); border-bottom:2rpx solid var(--color-line-soft); background:#fff; }
.workbench-item { min-height:172rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16rpx; color:var(--color-text); font-size:24rpx; font-weight:800; border-right:2rpx solid var(--color-line-soft); border-bottom:2rpx solid var(--color-line-soft); }
.workbench-item:nth-child(4n) { border-right:0; }
.workbench-item .icon { width:50rpx; height:50rpx; color:var(--color-primary-strong); }
.workbench-section { padding-top:20rpx; }
.func-row { min-height:144rpx; padding: 0 var(--page-x); display:grid; grid-template-columns: 72rpx 1fr auto; gap:24rpx; align-items:center; border-bottom:2rpx solid var(--color-line-soft); background:#fff; }
.func-icon { width:72rpx; height:72rpx; border-radius:26rpx; background:var(--color-primary-soft); color:var(--color-primary-strong); display:grid; place-items:center; }
.func-main strong { display:block; font-size:30rpx; font-weight:900; }
.func-main span { display:block; margin-top:8rpx; color:var(--color-muted); font-size:24rpx; line-height:1.35; }
.segment { display:flex; gap:16rpx; padding:20rpx var(--page-x); overflow:auto; border-bottom:2rpx solid var(--color-line-soft); scrollbar-width:none; }
.segment::-webkit-scrollbar { display:none; }
.segment button, .segment a { flex:0 0 auto; height:72rpx; padding:0 28rpx; border-radius:1998rpx; background:var(--color-bg-subtle); color:var(--color-text-2); font-size:26rpx; font-weight:900; display:flex; align-items:center; }
.segment .active { background:var(--color-primary); color:#fff; }
.type-list { padding: 0 var(--page-x); }
.type-card { display:grid; grid-template-columns:88rpx 1fr auto; gap:24rpx; align-items:center; min-height:168rpx; border-bottom:2rpx solid var(--color-line-soft); }
