.spec-option.active { background:var(--color-primary-soft); color:var(--color-primary-strong); }
.sku-table-card { margin: 0 var(--page-x) 24rpx; padding:28rpx; border-bottom:2rpx solid var(--color-line-soft); background:#fff; }
