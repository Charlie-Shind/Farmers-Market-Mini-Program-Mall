<view class="app-page">
<view class="status-space"></view>
<view class="page-titlebar"><navigator class="back-btn" url="/pages/merchant-design/orders/orders"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="title-block"><view class="page-title">评价管理</view><view class="page-subtitle">查看买家评价并回复</view></view></view>
<view class="data-grid-3"><view class="data-cell"><text>4.8</text><text>店铺评分</text></view><view class="data-cell"><text>96%</text><text>好评率</text></view><view class="data-cell"><text>12</text><text>待回复</text></view></view>
<view class="toolbar" data-chip-group="chips"><button class="chip active" data-chip="all">全部</button><button class="chip" data-chip="good">好评</button><button class="chip" data-chip="normal">中评</button><button class="chip" data-chip="bad">差评</button><button class="chip" data-chip="todo">待回复</button></view>
<view data-filter-list="1"><view class="order-item" data-status="good" data-tags="good,todo" data-search="李女士 蓝莓 好评"><view class="buyer-row"><view class="buyer-info"><image class="avatar" mode="aspectFill" src="/assets/avatars/a1.svg" /><view class="buyer-name">李女士</view></view><text class="status-pill warning">待回复</text></view><navigator class="product-row" url="/pages/merchant-design/order-detail/order-detail"><image class="goods-img" mode="aspectFill" src="/assets/goods/g2.svg" /><view class="product-main"><view class="product-title">果子很新鲜，包装也好，送礼很合适。</view><view class="product-sub">评分 5.0 · 高山蓝莓礼盒</view></view><view class="product-必填">5星</view></navigator><view class="item-actions"><button class="pill-btn" data-toast="已复制评价" bindtap="handleToast">复制</button><view class="btn-row"><button class="pill-btn primary" data-toast="已回复评价" bindtap="handleToast">回复评价</button></view></view></view><view class="order-item" data-status="normal" data-tags="normal" data-search="王女士 蔬菜 中评"><view class="buyer-row"><view class="buyer-info"><image class="avatar" mode="aspectFill" src="/assets/avatars/a2.svg" /><view class="buyer-name">王女士</view></view><text class="status-pill info">已回复</text></view><navigator class="product-row" url="/pages/merchant-design/order-detail/order-detail"><image class="goods-img" mode="aspectFill" src="/assets/goods/g8.svg" /><view class="product-main"><view class="product-title">蔬菜还可以，但是配送稍慢。</view><view class="product-sub">评分 3.0 · 家庭蔬菜礼盒</view></view><view class="product-必填">3星</view></navigator></view><view class="list-empty">没有匹配评价</view></view>
<view class="bottom-nav"><navigator url="/pages/merchant-design/dashboard/dashboard"><image class="icon" mode="aspectFit" src="/assets/icons/home.svg" /><text>首页</text></navigator><navigator url="/pages/merchant-design/messages/messages"><image class="icon" mode="aspectFit" src="/assets/icons/message.svg" /><text>聊天</text></navigator><navigator class="active" url="/pages/merchant-design/orders/orders"><image class="icon" mode="aspectFit" src="/assets/icons/order.svg" /><text>订单</text></navigator><navigator url="/pages/merchant-design/products/products"><image class="icon" mode="aspectFit" src="/assets/icons/box.svg" /><text>库存</text></navigator><navigator url="/pages/merchant-design/shop/shop"><image class="icon" mode="aspectFit" src="/assets/icons/user.svg" /><text>账号</text></navigator></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
