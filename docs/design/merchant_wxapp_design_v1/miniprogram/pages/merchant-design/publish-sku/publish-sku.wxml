<view class="app-page no-bottom with-sticky">
<view class="status-space"></view>
<view class="page-titlebar"><navigator class="back-btn" url="/pages/merchant-design/publish/publish"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="title-block"><view class="page-title">规格库存</view></view></view>
<view class="section-line-title"><text>规格模式</text></view><view class="segment"><button class="active" data-toast="多规格已启用" bindtap="handleToast">多规格</button><button data-toast="单规格已启用" bindtap="handleToast">单规格</button><button data-toast="已批量填充库存" bindtap="handleToast">批量填充</button></view>
<view class="spec-editor"><view class="spec-block"><view class="spec-block-head"><view class="spec-block-title">规格组：包装</view><view class="btn-row"><button class="pill-btn outline" data-toast="新增包装选项" bindtap="handleToast">新增</button><button class="pill-btn danger" data-toast="已删除包装规格组" bindtap="handleToast">删除组</button></view></view><view class="spec-option-wrap"><button class="spec-option active" data-multi-chip="1" bindtap="handleToggleMock">2盒装<text class="mini-x" data-delete-parent=".spec-option" bindtap="handleDeleteMock">×</text></button><button class="spec-option active" data-multi-chip="1" bindtap="handleToggleMock">4盒装<text class="mini-x" data-delete-parent=".spec-option" bindtap="handleDeleteMock">×</text></button><button class="spec-option" data-multi-chip="1" bindtap="handleToggleMock">8盒装<text class="mini-x" data-delete-parent=".spec-option" bindtap="handleDeleteMock">×</text></button></view></view><view class="spec-block"><view class="spec-block-head"><view class="spec-block-title">规格组：等级</view><view class="btn-row"><button class="pill-btn outline" data-toast="新增等级选项" bindtap="handleToast">新增</button><button class="pill-btn danger" data-toast="已删除等级规格组" bindtap="handleToast">删除组</button></view></view><view class="spec-option-wrap"><button class="spec-option active" data-multi-chip="1" bindtap="handleToggleMock">精选<text class="mini-x" data-delete-parent=".spec-option" bindtap="handleDeleteMock">×</text></button><button class="spec-option active" data-multi-chip="1" bindtap="handleToggleMock">特级<text class="mini-x" data-delete-parent=".spec-option" bindtap="handleDeleteMock">×</text></button></view></view></view>
<view class="section-line-title"><text>规格组合</text><button class="row-right" data-toast="已批量同步价格" bindtap="handleToast">同步价格</button></view>
<view class="panel-line"><view class="sku-card"><view class="sku-head"><view class="sku-title-row"><view class="sku-name">2盒装 / 精选</view><view class="product-sub">编码：BB-2-JX</view></view><view class="sku-tools"><button class="pill-btn outline" data-toast="已停用该规格" bindtap="handleToast">停用</button><button class="pill-btn danger" data-delete-parent=".sku-card" bindtap="handleDeleteMock">删除</button></view></view><view class="sku-grid"><view class="sku-field"><view>价格</view><input value="158" /></view><view class="sku-field"><view>库存</view><input value="86" /></view><view class="sku-field"><view>活动价</view><input value="128" /></view><view class="sku-field"><view>限购</view><input value="2" /></view></view></view><view class="sku-card"><view class="sku-head"><view class="sku-title-row"><view class="sku-name">4盒装 / 特级</view><view class="product-sub">编码：BB-4-TJ</view></view><view class="sku-tools"><button class="pill-btn outline" data-toast="已停用该规格" bindtap="handleToast">停用</button><button class="pill-btn danger" data-delete-parent=".sku-card" bindtap="handleDeleteMock">删除</button></view></view><view class="sku-grid"><view class="sku-field"><view>价格</view><input value="298" /></view><view class="sku-field"><view>库存</view><input value="168" /></view><view class="sku-field"><view>活动价</view><input value="238" /></view><view class="sku-field"><view>限购</view><input value="2" /></view></view></view><view class="sku-card"><view class="sku-head"><view class="sku-title-row"><view class="sku-name">8盒装 / 特级</view><view class="product-sub">编码：BB-8-TJ</view></view><view class="sku-tools"><button class="pill-btn outline" data-toast="已停用该规格" bindtap="handleToast">停用</button><button class="pill-btn danger" data-delete-parent=".sku-card" bindtap="handleDeleteMock">删除</button></view></view><view class="sku-grid"><view class="sku-field"><view>价格</view><input value="568" /></view><view class="sku-field"><view>库存</view><input value="12" /></view><view class="sku-field"><view>活动价</view><input value="498" /></view><view class="sku-field"><view>限购</view><input value="1" /></view></view></view></view>
<view class="bottom-actions"><button class="action-btn secondary" data-toast="已保存规格草稿" bindtap="handleToast">保存草稿</button><navigator class="action-btn" url="/pages/merchant-design/publish/publish">保存并返回</navigator></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
