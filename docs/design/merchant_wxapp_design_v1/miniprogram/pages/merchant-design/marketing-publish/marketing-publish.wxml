<view class="app-page no-bottom with-sticky">
<view class="status-space"></view>
<view class="page-titlebar">
<navigator class="back-btn" url="/pages/merchant-design/marketing/marketing"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator>
<view class="title-block"><view class="page-title">发布活动</view></view>
<navigator class="icon-action" url="/pages/merchant-design/marketing-drafts/marketing-drafts"><image class="icon" mode="aspectFit" src="/assets/icons/bill.svg" /><text>草稿</text></navigator>
</view>
<!-- 活动类型：后续转小程序时对应 radio-group / 自定义卡片单选组件 -->
<view class="section-line-title"><text>选择活动类型</text><text class="status-pill info" data-type-result="1">限时秒杀</text></view>
<view class="activity-type-grid compact">
<button class="activity-type-card {{activityType === 'seckill' ? 'active' : ''}}" data-activity-type="秒杀" data-activity-type-value="seckill" bindtap="chooseActivityType">
<image mode="aspectFill" src="/assets/illustrations/activity.svg" />
<text>限时秒杀</text>
<text>价格、库存、限购</text>
</button>
<button class="activity-type-card {{activityType === 'group' ? 'active' : ''}}" data-activity-type="拼团" data-activity-type-value="group" bindtap="chooseActivityType">
<image mode="aspectFill" src="/assets/illustrations/store.svg" />
<text>拼团活动</text>
<text>人数、团时、团价</text>
</button>
<button class="activity-type-card {{activityType === 'coupon' ? 'active' : ''}}" data-activity-type="满减券" data-activity-type-value="coupon" bindtap="chooseActivityType">
<image mode="aspectFill" src="/assets/illustrations/finance.svg" />
<text>满减优惠券</text>
<text>门槛、金额、库存</text>
</button>
<button class="activity-type-card {{activityType === 'presell' ? 'active' : ''}}" data-activity-type="预售" data-activity-type-value="presell" bindtap="chooseActivityType">
<image mode="aspectFill" src="/assets/illustrations/delivery.svg" />
<text>预售活动</text>
<text>定金、尾款、发货</text>
</button>
</view>
<!-- 基础信息：日期时间字段用 input 先模拟 picker，后续可替换微信小程序 picker / picker-view -->
<view class="section-line-title"><text>基础信息</text></view>
<view class="full-list">
<view class="form-line"><view>活动名称<text>必填</text></view><input value="端午产地直供限时活动" /></view>
<view class="picker-line">
<view class="picker-main"><view>开始时间</view><input type="text" value="2026-06-20T20:00" /></view>
<image class="icon-sm" mode="aspectFit" src="/assets/icons/clock.svg" />
</view>
<view class="picker-line">
<view class="picker-main"><view>结束时间</view><input type="text" value="2026-06-22T20:00" /></view>
<image class="icon-sm" mode="aspectFit" src="/assets/icons/clock.svg" />
</view>
<view class="picker-line">
<view class="picker-main"><view>活动预热</view><view><text>开始前 2 小时展示</text></view></view>
<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" />
</view>
</view>
<!-- 秒杀配置 -->
<view class="activity-config {{activityType === 'seckill' ? '' : 'hidden'}}" data-activity-config="seckill">
<view class="section-line-title"><text>秒杀配置</text></view>
<view class="rule-form-grid">
<view class="number-cell"><text>秒杀价</text><view><text>¥</text><input type="number" value="238" /></view></view>
<view class="number-cell"><text>活动库存</text><view><input type="number" value="168" /><text>件</text></view></view>
<view class="number-cell"><text>每人限购</text><view><input type="number" value="2" /><text>件</text></view></view>
<view class="number-cell"><text>库存预警</text><view><input type="number" value="30" /><text>件</text></view></view>
</view>
<view class="full-list">
<view class="picker-line"><view class="picker-main"><view>秒杀时段</view><view><text>全天场</text></view></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view>
<view class="picker-line"><view class="picker-main"><view>扣减库存</view><view><text>下单扣减</text></view></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view>
<view class="switch-row"><text class="switch-main"><text>售罄自动结束</text><text>库存为 0 时活动自动关闭</text></text><button class="fake-switch active" data-switch="1" bindtap="toggleSwitch"></button></view>
</view>
</view>
<!-- 拼团配置 -->
<view class="activity-config hidden {{activityType === 'group' ? '' : 'hidden'}}" data-activity-config="group">
<view class="section-line-title"><text>拼团配置</text></view>
<view class="rule-form-grid">
<view class="number-cell"><text>拼团价</text><view><text>¥</text><input type="number" value="59" /></view></view>
<view class="number-cell"><text>成团人数</text><view><input type="number" value="3" /><text>人</text></view></view>
<view class="number-cell"><text>团有效期</text><view><input type="number" value="24" /><text>小时</text></view></view>
<view class="number-cell"><text>每人限购</text><view><input type="number" value="2" /><text>件</text></view></view>
</view>
<view class="full-list">
<view class="picker-line"><view class="picker-main"><view>成团方式</view><view><text>满员成团</text></view></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view>
<view class="picker-line"><view class="picker-main"><view>开团时间</view><input type="text" value="2026-06-20T10:00" /></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/clock.svg" /></view>
<view class="switch-row"><text class="switch-main"><text>允许拼团分享</text><text>买家可转发邀请好友参团</text></text><button class="fake-switch active" data-switch="1" bindtap="toggleSwitch"></button></view>
</view>
</view>
<!-- 满减券配置 -->
<view class="activity-config hidden {{activityType === 'coupon' ? '' : 'hidden'}}" data-activity-config="coupon">
<view class="section-line-title"><text>满减券配置</text></view>
<view class="rule-form-grid">
<view class="number-cell"><text>使用门槛</text><view><text>¥</text><input type="number" value="100" /></view></view>
<view class="number-cell"><text>优惠金额</text><view><text>¥</text><input type="number" value="10" /></view></view>
<view class="number-cell"><text>券库存</text><view><input type="number" value="300" /><text>张</text></view></view>
<view class="number-cell"><text>每人限领</text><view><input type="number" value="1" /><text>张</text></view></view>
</view>
<view class="full-list">
<view class="picker-line"><view class="picker-main"><view>领取时间</view><input type="text" value="2026-06-20T08:00" /></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/clock.svg" /></view>
<view class="picker-line"><view class="picker-main"><view>使用有效期</view><view><text>领取后 7 天内</text></view></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view>
<view class="picker-line"><view class="picker-main"><view>适用范围</view><view><text>已选商品可用</text></view></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view>
</view>
</view>
<!-- 预售配置 -->
<view class="activity-config hidden {{activityType === 'presell' ? '' : 'hidden'}}" data-activity-config="presell">
<view class="section-line-title"><text>预售配置</text></view>
<view class="rule-form-grid">
<view class="number-cell"><text>预售价</text><view><text>¥</text><input type="number" value="128" /></view></view>
<view class="number-cell"><text>定金</text><view><text>¥</text><input type="number" value="20" /></view></view>
<view class="number-cell"><text>预售库存</text><view><input type="number" value="200" /><text>件</text></view></view>
<view class="number-cell"><text>限购</text><view><input type="number" value="2" /><text>件</text></view></view>
</view>
<view class="full-list">
<view class="picker-line"><view class="picker-main"><view>尾款开始</view><input type="text" value="2026-06-24T10:00" /></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/clock.svg" /></view>
<view class="picker-line"><view class="picker-main"><view>尾款结束</view><input type="text" value="2026-06-26T22:00" /></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/clock.svg" /></view>
<view class="picker-line"><view class="picker-main"><view>预计发货</view><input type="text" value="2026-06-28" /></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/truck.svg" /></view>
</view>
</view>
<view class="section-line-title"><text>参与商品</text><navigator class="row-right" url="/pages/merchant-design/marketing-products/marketing-products">选择商品<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></navigator></view>
<view id="publishActivityProducts">
<view class="goods-select-row selected" data-toggle-check="1" bindtap="handleToggleMock"><view class="check-dot active"><image class="icon-sm" mode="aspectFit" src="/assets/icons/check.svg" /></view><image class="goods-img sm" mode="aspectFill" src="/assets/goods/g2.svg" /><view><view class="product-title">高山蓝莓礼盒 4盒装</view><view class="product-sub">库存 168 · 原价 ¥298 · 活动价 ¥238</view></view></view>
<view class="goods-select-row selected" data-toggle-check="1" bindtap="handleToggleMock"><view class="check-dot active"><image class="icon-sm" mode="aspectFit" src="/assets/icons/check.svg" /></view><image class="goods-img sm" mode="aspectFill" src="/assets/goods/g8.svg" /><view><view class="product-title">产地直供蔬菜礼盒</view><view class="product-sub">库存 220 · 活动价 ¥49</view></view></view>
</view>
<view class="bottom-actions three"><button class="action-btn secondary" data-toast="已保存活动草稿" bindtap="handleToast">保存草稿</button><navigator class="action-btn secondary" url="/pages/merchant-design/marketing/marketing">取消</navigator><button class="action-btn" data-toast="已创建活动" bindtap="handleToast">发布活动</button></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
