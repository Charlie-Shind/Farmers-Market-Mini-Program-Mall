<view class="app-page no-bottom chat-page"><view class="status-space"></view>
<view class="page-titlebar"><navigator class="back-btn" url="/pages/merchant-design/messages/messages"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="title-block"><view class="page-title">李女士</view><view class="page-subtitle">订单 WY20260618001 · 待发货</view></view><button class="icon-action" data-open-sheet="contactSheet" bindtap="openSheet"><image class="icon" mode="aspectFit" src="/assets/icons/message.svg" /><text>联系</text></button></view>
<view class="demo-card-list"><navigator class="demo-card" url="/pages/merchant-design/order-detail/order-detail"><image mode="aspectFill" src="/assets/goods/g2.svg" /><view><view class="demo-title">高山蓝莓礼盒 4盒装</view><view class="demo-desc">待发货 · ¥268.00 · 顺丰冷链</view></view><view class="demo-right">订单</view></navigator></view>
<view class="chat-flow"><view class="message-bubble">您好，蓝莓今天能发货吗？我周末想送礼。</view><view class="message-bubble me">可以的，今天 18:00 前会录入顺丰冷链单号。</view><view class="message-bubble">好的，麻烦帮我备注一下不要挤压。</view><view class="message-bubble me">已备注，包装会加固处理。</view></view>
<view class="chat-input-bar"><button class="round-tool" data-open-sheet="quickReply" bindtap="openSheet"><image class="icon-sm" mode="aspectFit" src="/assets/icons/plus.svg" /></button><input placeholder="输入回复内容" /><button class="pill-btn primary" data-toast="已发送消息" bindtap="handleToast">发送</button></view>
<view class="sheet-mask {{activeSheet ? 'show' : ''}}" data-sheet-mask="1" bindtap="closeSheet"></view><view class="sheet {{activeSheet === 'contactSheet' ? 'show' : ''}}" id="contactSheet"><view class="sheet-head"><view class="sheet-title">联系买家</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="contact-sheet-row" data-phone="13800000000" bindtap="makePhoneCall"><view><text>电话联系</text><text>138****8821</text></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view><button class="contact-sheet-row" data-toast="已复制微信号" bindtap="handleToast"><view><text>复制微信号</text><text>wanyuan_farm</text></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></button><navigator class="contact-sheet-row" url="/pages/merchant-design/order-detail/order-detail"><view><text>查看订单</text><text>订单、地址、物流</text></view><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></navigator></view></view>
<view class="sheet {{activeSheet === 'quickReply' ? 'show' : ''}}" id="quickReply"><view class="sheet-head"><view class="sheet-title">快捷回复</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="option-grid"><button class="option" data-toast="已插入：今天发货" bindtap="handleToast">今天发货</button><button class="option" data-toast="已插入：已备注" bindtap="handleToast">已备注</button><button class="option" data-toast="已插入：物流稍后更新" bindtap="handleToast">物流稍后更新</button><button class="option" data-toast="已插入：包装已加固" bindtap="handleToast">包装已加固</button></view></view></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
