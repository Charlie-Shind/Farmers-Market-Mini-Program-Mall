<view class="app-page no-bottom with-sticky">
<view class="status-space"></view>
<view class="page-titlebar">
<view class="back-btn" bindtap="goBack"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></view><view class="title-block"><view class="page-title">订单详情</view><view class="page-subtitle">WY20260618001</view></view><text class="status-pill warning">待发货</text>
</view>
<view class="full-list">
<view class="notice-row"><view class="row-main"><view class="row-title">买家已付款，等待商家发货</view><view class="row-desc">请在 24 小时内录入物流信息</view></view><button class="pill-btn primary" data-open-sheet="shipSheet" bindtap="openSheet">去发货</button></view>
</view><view class="divider"></view>
<view class="section-line-title">买家信息</view>
<view class="full-list">
<navigator class="notice-row" url="/pages/merchant-design/chat-detail/chat-detail"><view class="buyer-info"><image class="avatar" mode="aspectFill" src="/assets/avatars/a1.svg" /><view><view class="row-title">王小禾</view><view class="row-desc">收货地：浙江杭州 · 下单 18:24</view></view></view><view class="row-right">聊天<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></navigator>
<view class="notice-row"><view class="row-main"><view class="row-title">浙江省杭州市西湖区文三路 88 号</view><view class="row-desc">王小禾 138****8821</view></view><button class="pill-btn outline" data-toast="已复制地址" bindtap="handleToast">复制</button></view>
</view><view class="divider"></view>
<view class="section-line-title">商品</view>
<view class="full-list">
<navigator class="product-list-item" url="/pages/merchant-design/product-edit/product-edit"><image class="goods-img" mode="aspectFill" src="/assets/goods/g2.svg" /><view class="product-list-body"><view class="product-list-head"><view class="product-list-title">湾源农仓 蓝莓礼盒 顺丰冷链装</view><text class="status-pill success">1件</text></view><view class="product-list-meta">规格：2kg礼盒 · 产地：云南</view><view class="product-list-bottom"><text class="必填-main">¥268.00</text><text class="row-right">含冷链包装</text></view></view></navigator>
</view><view class="divider"></view>
<view class="section-line-title">金额明细</view>
<view class="full-list">
<view class="finance-row"><text>商品金额</text><text>¥268.00</text></view><view class="finance-row"><text>运费</text><text>¥0.00</text></view><view class="finance-row"><text>平台服务费</text><text>-¥8.04</text></view><view class="finance-row"><text>预计入账</text><text class="status-text success">¥259.96</text></view>
</view><view class="bottom-actions"><navigator class="action-btn secondary" url="/pages/merchant-design/chat-detail/chat-detail">联系买家</navigator><button class="action-btn" data-open-sheet="shipSheet" bindtap="openSheet">录入物流</button></view>
<view class="sheet-mask {{activeSheet ? 'show' : ''}}" data-sheet-mask="1" bindtap="closeSheet"></view><view class="sheet {{activeSheet === 'shipSheet' ? 'show' : ''}}" id="shipSheet"><view class="sheet-head"><view class="sheet-title">录入物流</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="sheet-label">物流公司</view><view class="option-grid"><button class="option active">顺丰速运</button><button class="option">中通快递</button><button class="option">京东物流</button><button class="option">其它</button></view></view><view class="sheet-group"><view class="sheet-label">发货方式</view><view class="option-grid"><button class="option active">快递发货</button><button class="option">同城配送</button><button class="option">无需物流</button></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-toast="已清空物流信息" bindtap="handleToast">清空</button><button class="action-btn" data-toast="已保存物流" data-close-sheet="1" bindtap="handleToast" bindtap="closeSheet">保存物流</button></view></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
