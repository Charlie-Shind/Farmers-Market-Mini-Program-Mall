<view class="app-page no-bottom with-sticky">
<view class="status-space"></view>
<view class="app-topbar">
<view class="back-btn" bindtap="goBack"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></view>
<view class="search-pill"><image class="icon-sm" mode="aspectFit" src="/assets/icons/search.svg" /><input data-search-input="1" placeholder="搜索草稿商品" /></view>
<button class="icon-action" data-open-sheet="draftFilter" bindtap="openSheet"><image class="icon" mode="aspectFit" src="/assets/icons/filter.svg" /><text>筛选</text></button>
</view>
<view class="tabs" data-filter-tabs="1"><button class="tab active" data-filter="all"><text>全部</text></button><button class="tab" data-filter="image"><text>缺图片</text></button><button class="tab" data-filter="必填"><text>缺价格</text></button><button class="tab" data-filter="sku"><text>缺规格</text></button><button class="tab" data-filter="ready"><text>可提交</text></button></view>
<view class="full-list" data-filter-list="1">
<view class="draft-row" data-status="ready" data-search="蓝莓礼盒 顺丰冷链 可提交"> <view class="draft-mark"><image class="icon" mode="aspectFit" src="/assets/icons/edit.svg" /></view><view class="draft-main"><view class="draft-title">湾源农仓 蓝莓礼盒 顺丰冷链装</view><view class="draft-desc">已完成 8/9 项 · 12 分钟前保存</view></view><navigator class="pill-btn primary" url="/pages/merchant-design/product-edit/product-edit">继续编辑</navigator></view>
<view class="draft-row" data-status="image" data-search="山货礼盒 缺图片"> <view class="draft-mark"><image class="icon" mode="aspectFit" src="/assets/icons/camera.svg" /></view><view class="draft-main"><view class="draft-title">山货礼盒端午组合装</view><view class="draft-desc">缺少主图 · 昨天 22:15 保存</view></view><navigator class="pill-btn" url="/pages/merchant-design/product-edit/product-edit">补图片</navigator></view>
<view class="draft-row" data-status="sku" data-search="土鸡蛋 缺规格"> <view class="draft-mark"><image class="icon" mode="aspectFit" src="/assets/icons/box.svg" /></view><view class="draft-main"><view class="draft-title">林下散养土鸡蛋 30枚</view><view class="draft-desc">缺少规格库存 · 2 天前保存</view></view><navigator class="pill-btn" url="/pages/merchant-design/publish-sku/publish-sku">补规格</navigator></view>
<view class="list-empty">没有匹配草稿</view>
</view>
<view class="bottom-actions"><button class="action-btn secondary" data-toast="已清理无效草稿" bindtap="handleToast">清理无效草稿</button><navigator class="action-btn" style="display:flex;align-items:center;justify-content:center" url="/pages/merchant-design/publish/publish">发布新商品</navigator></view>
<view class="sheet-mask {{activeSheet ? 'show' : ''}}" data-sheet-mask="1" bindtap="closeSheet"></view><view class="sheet {{activeSheet === 'draftFilter' ? 'show' : ''}}" id="draftFilter"><view class="sheet-head"><view class="sheet-title">草稿筛选</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="sheet-label">完整度</view><view class="option-grid"><button class="option active">全部</button><button class="option">可提交</button><button class="option">缺图片</button><button class="option">缺规格</button></view></view><view class="sheet-group"><view class="sheet-label">保存时间</view><view class="option-grid"><button class="option active">最近保存</button><button class="option">今天</button><button class="option">7天内</button></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-toast="已重置筛选" bindtap="handleToast">重置</button><button class="action-btn" data-close-sheet="1" data-toast="已应用筛选" bindtap="handleToast" bindtap="closeSheet">应用</button></view></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
