<view class="app-page no-bottom with-sticky"><view class="status-space"></view>
<view class="page-titlebar"><view class="back-btn" bindtap="goBack"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></view><view class="title-block"><view class="page-title">配送设置</view></view><button class="icon-action" data-toast="已保存配送设置" bindtap="handleToast"><image class="icon" mode="aspectFit" src="/assets/icons/check.svg" /><text>保存</text></button></view>
<view class="section-line-title"><text>发货地址</text><button class="row-right" data-open-sheet="addressSheet" bindtap="openSheet">编辑<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></button></view>
<view class="delivery-card"><view class="delivery-row"><view class="delivery-icon"><image class="icon-sm" mode="aspectFit" src="/assets/icons/store.svg" /></view><view><view class="delivery-title">湾源农仓发货仓</view><view class="delivery-desc">云南省楚雄州双柏县产业园 3 号仓</view></view><text class="status-pill success">默认</text></view></view>
<view class="section-line-title"><text>运费模板</text></view>
<view class="delivery-card"><button class="delivery-row" data-open-sheet="deliverySheet" bindtap="openSheet"><view class="delivery-icon"><image class="icon-sm" mode="aspectFit" src="/assets/icons/bill.svg" /></view><view><view class="delivery-title">满额包邮</view><view class="delivery-desc">满 99 元包邮，未满收 8 元</view></view><view class="row-right">编辑<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></button><button class="delivery-row" data-open-sheet="areaSheet" bindtap="openSheet"><view class="delivery-icon"><image class="icon-sm" mode="aspectFit" src="/assets/icons/truck.svg" /></view><view><view class="delivery-title">配送范围</view><view class="delivery-desc">全国配送，冷链限制部分地区</view></view><view class="row-right">设置<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></button><view class="delivery-row"><view class="delivery-icon"><image class="icon-sm" mode="aspectFit" src="/assets/icons/shield.svg" /></view><view><view class="delivery-title">冷链提示</view><view class="delivery-desc">生鲜商品详情展示冷链说明</view></view><button class="fake-switch active" data-switch="1" bindtap="toggleSwitch"></button></view></view>
<view class="section-line-title"><text>快递偏好</text></view>
<view class="delivery-card"><view class="delivery-row"><view class="delivery-icon"><image class="icon-sm" mode="aspectFit" src="/assets/icons/truck.svg" /></view><view><view class="delivery-title">优先快递</view><view class="delivery-desc">顺丰速运 / 京东物流</view></view><button class="pill-btn outline" data-open-sheet="expressSheet" bindtap="openSheet">选择</button></view><view class="delivery-row"><view class="delivery-icon"><image class="icon-sm" mode="aspectFit" src="/assets/icons/bell.svg" /></view><view><view class="delivery-title">发货提醒</view><view class="delivery-desc">订单付款后 2 小时提醒</view></view><button class="fake-switch active" data-switch="1" bindtap="toggleSwitch"></button></view></view>
<view class="bottom-actions"><button class="action-btn secondary" data-toast="已恢复默认设置" bindtap="handleToast">恢复默认</button><button class="action-btn" data-toast="已保存配送设置" bindtap="handleToast">保存设置</button></view>
<view class="sheet-mask {{activeSheet ? 'show' : ''}}" data-sheet-mask="1" bindtap="closeSheet"></view>
<view class="sheet {{activeSheet === 'addressSheet' ? 'show' : ''}}" id="addressSheet"><view class="sheet-head"><view class="sheet-title">发货地址</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="inline-field"><view>联系人</view><input value="王师傅" /></view></view><view class="sheet-group"><view class="inline-field"><view>联系电话</view><input value="138****8821" /></view></view><view class="sheet-group"><view class="inline-field"><view>详细地址</view><input value="云南省楚雄州双柏县产业园 3 号仓" /></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-close-sheet="1" bindtap="closeSheet">取消</button><button class="action-btn" data-toast="已保存地址" data-close-sheet="1" bindtap="handleToast" bindtap="closeSheet">保存</button></view></view>
<view class="sheet {{activeSheet === 'deliverySheet' ? 'show' : ''}}" id="deliverySheet"><view class="sheet-head"><view class="sheet-title">运费模板</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="sheet-label">模板类型</view><view class="option-grid"><button class="option active">满额包邮</button><button class="option">固定运费</button><button class="option">按地区收费</button></view></view><view class="sheet-group"><view class="form-two"><view class="inline-field"><view>包邮门槛</view><input value="99" /></view><view class="inline-field"><view>基础运费</view><input value="8" /></view></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-close-sheet="1" bindtap="closeSheet">取消</button><button class="action-btn" data-toast="已保存运费模板" data-close-sheet="1" bindtap="handleToast" bindtap="closeSheet">保存</button></view></view>
<view class="sheet {{activeSheet === 'areaSheet' ? 'show' : ''}}" id="areaSheet"><view class="sheet-head"><view class="sheet-title">配送范围</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="sheet-label">范围</view><view class="option-grid"><button class="option active">全国</button><button class="option">省内</button><button class="option">同城</button><button class="option">自定义</button></view></view><view class="sheet-group"><view class="sheet-label">限制地区</view><view class="multi-chip-row"><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">冷链不可达</button><button class="multi-chip" data-multi-chip="1" bindtap="handleToggleMock">偏远地区</button><button class="multi-chip" data-multi-chip="1" bindtap="handleToggleMock">港澳台</button></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-close-sheet="1" bindtap="closeSheet">取消</button><button class="action-btn" data-toast="已保存配送范围" data-close-sheet="1" bindtap="handleToast" bindtap="closeSheet">保存</button></view></view>
<view class="sheet {{activeSheet === 'expressSheet' ? 'show' : ''}}" id="expressSheet"><view class="sheet-head"><view class="sheet-title">快递偏好</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="option-grid"><button class="option active">顺丰速运</button><button class="option active">京东物流</button><button class="option">中通快递</button><button class="option">圆通速递</button></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-close-sheet="1" bindtap="closeSheet">取消</button><button class="action-btn" data-toast="已保存快递偏好" data-close-sheet="1" bindtap="handleToast" bindtap="closeSheet">保存</button></view></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
