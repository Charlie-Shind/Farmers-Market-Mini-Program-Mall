<view class="app-page no-bottom"><view class="status-space"></view>
<view class="page-titlebar"><view class="back-btn" bindtap="goBack"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></view><view class="title-block"><view class="page-title">库存调整</view></view><button class="icon-action" data-open-sheet="stockFilter" bindtap="openSheet"><image class="icon" mode="aspectFit" src="/assets/icons/filter.svg" /><text>筛选</text></button></view>
<view class="toolbar" data-chip-group="chips"><button class="chip active" data-chip="all">全部</button><button class="chip" data-chip="low">低库存</button><button class="chip" data-chip="zero">无库存</button><button class="chip" data-chip="normal">正常</button></view>
<view class="full-list" data-filter-list="1">
<view class="product-list-item" data-status="normal" data-search="蓝莓礼盒 顺丰冷链装 42"><image class="goods-img" mode="aspectFill" src="/assets/goods/g2.svg" /><view class="product-list-body"><view class="product-list-head"><view class="product-list-title">蓝莓礼盒 顺丰冷链装</view><text class="status-pill success">库存 42</text></view><view class="product-list-meta">现货商品 · 冷链配送</view><view class="product-list-bottom"><text class="row-right">已上架</text><view class="btn-row"><button class="pill-btn" data-toast="减少库存" bindtap="handleToast">减少</button><button class="pill-btn primary" data-toast="增加库存" bindtap="handleToast">增加</button></view></view></view></view>
<view class="product-list-item" data-status="low" data-search="高山土鸡蛋 30枚装 6"><image class="goods-img" mode="aspectFill" src="/assets/goods/g3.svg" /><view class="product-list-body"><view class="product-list-head"><view class="product-list-title">高山土鸡蛋 30枚装</view><text class="status-pill warning">库存 6</text></view><view class="product-list-meta">现货商品 · 库存预警</view><view class="product-list-bottom"><text class="row-right">已上架</text><view class="btn-row"><button class="pill-btn" data-toast="减少库存" bindtap="handleToast">减少</button><button class="pill-btn primary" data-toast="增加库存" bindtap="handleToast">增加</button></view></view></view></view>
<view class="product-list-item" data-status="zero" data-search="山货干货礼盒 0"><image class="goods-img" mode="aspectFill" src="/assets/goods/g6.svg" /><view class="product-list-body"><view class="product-list-head"><view class="product-list-title">山货干货礼盒</view><text class="status-pill danger">库存 0</text></view><view class="product-list-meta">自动下架 · 需补库存</view><view class="product-list-bottom"><text class="row-right">已下架</text><view class="btn-row"><button class="pill-btn" data-toast="减少库存" bindtap="handleToast">减少</button><button class="pill-btn primary" data-toast="增加库存" bindtap="handleToast">增加</button></view></view></view></view>
<view class="list-empty">没有匹配商品</view></view>
<view class="sheet-mask {{activeSheet ? 'show' : ''}}" data-sheet-mask="1" bindtap="closeSheet"></view><view class="sheet {{activeSheet === 'stockFilter' ? 'show' : ''}}" id="stockFilter"><view class="sheet-head"><view class="sheet-title">库存筛选</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="sheet-label">库存情况</view><view class="option-grid"><button class="option active">全部</button><button class="option">低库存</button><button class="option">无库存</button><button class="option">正常</button></view></view><view class="sheet-group"><view class="sheet-label">商品分类</view><view class="option-grid"><button class="option active">全部</button><button class="option">时令果蔬</button><button class="option">特产礼盒</button><button class="option">粮油干货</button></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-toast="已重置筛选" bindtap="handleToast">重置</button><button class="action-btn" data-toast="已应用筛选" data-close-sheet="1" bindtap="handleToast" bindtap="closeSheet">应用筛选</button></view></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
