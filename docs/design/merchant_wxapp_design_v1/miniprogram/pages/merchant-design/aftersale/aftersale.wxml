<view class="app-page">
<view class="status-space"></view>
<view class="app-topbar"><navigator class="back-btn" url="/pages/merchant-design/workbench/workbench"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="search-pill"><image class="icon-sm" mode="aspectFit" src="/assets/icons/search.svg" /><input data-search-input="1" placeholder="搜索买家 / 订单号 / 商品" /></view><button class="icon-action" data-open-sheet="afterFilter" bindtap="openSheet"><image class="icon" mode="aspectFit" src="/assets/icons/filter.svg" /><text>筛选</text></button></view>
<view class="tabs" data-filter-tabs="1"><button class="tab active" data-filter="all"><text>全部</text></button><button class="tab" data-filter="pending"><text>待处理</text></button><button class="tab" data-filter="return"><text>退货中</text></button><button class="tab" data-filter="done"><text>已完成</text></button></view>
<view data-filter-list="1"><view class="order-item" data-status="pending" data-search="赵先生 仅退款 时令果蔬组合"><view class="buyer-row"><view class="buyer-info"><image class="avatar" mode="aspectFill" src="/assets/avatars/a3.svg" /><view class="buyer-name">赵先生</view></view><text class="status-text danger">仅退款待处理</text></view><navigator class="product-row" url="/pages/merchant-design/refund/refund"><image class="goods-img" mode="aspectFill" src="/assets/goods/g1.svg" /><view class="product-main"><view class="product-title">时令果蔬组合</view><view class="product-sub">退款金额 ¥76.00 · 原因：不想要了</view></view><view class="product-必填">¥76</view></navigator><view class="item-actions"><navigator class="more-link" url="/pages/merchant-design/refund/refund">详情</navigator><view class="btn-row"><button class="pill-btn" data-toast="已联系买家" bindtap="handleToast">联系买家</button><navigator class="pill-btn primary" url="/pages/merchant-design/refund/refund">处理</navigator></view></view></view><view class="order-item" data-status="return" data-search="王女士 退货退款 蓝莓礼盒"><view class="buyer-row"><view class="buyer-info"><image class="avatar" mode="aspectFill" src="/assets/avatars/a2.svg" /><view class="buyer-name">王女士</view></view><text class="status-text">退货中</text></view><navigator class="product-row" url="/pages/merchant-design/refund/refund"><image class="goods-img" mode="aspectFill" src="/assets/goods/g2.svg" /><view class="product-main"><view class="product-title">高山蓝莓礼盒</view><view class="product-sub">退货物流待买家填写</view></view><view class="product-必填">¥238</view></navigator><view class="item-actions"><navigator class="more-link" url="/pages/merchant-design/refund/refund">详情</navigator><view class="btn-row"><button class="pill-btn" data-toast="已催买家寄回" bindtap="handleToast">催寄回</button></view></view></view><view class="order-item" data-status="done" data-search="周周 已完成 山货干货"><view class="buyer-row"><view class="buyer-info"><image class="avatar" mode="aspectFill" src="/assets/avatars/a4.svg" /><view class="buyer-name">周周</view></view><text class="status-text success">已完成</text></view><navigator class="product-row" url="/pages/merchant-design/refund/refund"><image class="goods-img" mode="aspectFill" src="/assets/goods/g6.svg" /><view class="product-main"><view class="product-title">山货干货礼盒</view><view class="product-sub">退款 ¥20.00 · 协商补偿</view></view><view class="product-必填">¥20</view></navigator></view><view class="list-empty">没有匹配售后</view></view><view class="sheet-mask {{activeSheet ? 'show' : ''}}" data-sheet-mask="1" bindtap="closeSheet"></view><view class="sheet {{activeSheet === 'afterFilter' ? 'show' : ''}}" id="afterFilter"><view class="sheet-head"><view class="sheet-title">售后筛选</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="sheet-label">售后类型</view><view class="option-grid"><button class="option active">全部</button><button class="option">仅退款</button><button class="option">退货退款</button><button class="option">补偿</button></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn" data-close-sheet="1" data-toast="已应用筛选" bindtap="handleToast" bindtap="closeSheet">应用</button></view></view>
<view class="bottom-nav"><navigator url="/pages/merchant-design/dashboard/dashboard"><image class="icon" mode="aspectFit" src="/assets/icons/home.svg" /><text>首页</text></navigator><navigator url="/pages/merchant-design/messages/messages"><image class="icon" mode="aspectFit" src="/assets/icons/message.svg" /><text>聊天</text></navigator><navigator class="active" url="/pages/merchant-design/orders/orders"><image class="icon" mode="aspectFit" src="/assets/icons/order.svg" /><text>订单</text></navigator><navigator url="/pages/merchant-design/products/products"><image class="icon" mode="aspectFit" src="/assets/icons/box.svg" /><text>库存</text></navigator><navigator url="/pages/merchant-design/shop/shop"><image class="icon" mode="aspectFit" src="/assets/icons/user.svg" /><text>账号</text></navigator></view>
</view>

