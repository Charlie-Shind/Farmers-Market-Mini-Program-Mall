<view class="app-page no-bottom with-sticky">
<view class="status-space"></view>
<view class="app-topbar"><navigator class="back-btn" url="/pages/merchant-design/marketing-edit/marketing-edit"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="search-pill"><image class="icon-sm" mode="aspectFit" src="/assets/icons/search.svg" /><input data-search-input="1" placeholder="搜索商品名称 / 规格 / 分类" /></view><navigator class="icon-action" url="/pages/merchant-design/marketing-edit/marketing-edit"><image class="icon" mode="aspectFit" src="/assets/icons/check.svg" /><text>完成</text></navigator></view>
<view class="toolbar" data-chip-group="chips"><button class="chip active" data-chip="all">全部</button><button class="chip" data-chip="fruit">果蔬</button><button class="chip" data-chip="gift">礼盒</button><button class="chip" data-chip="low">低库存</button><button class="chip" data-chip="active">活动中</button></view>
<view class="section-line-title"><text>已选商品</text><text class="status-pill info"><text data-selected-count="#productPickList">0</text> 个</text></view>
<view id="productPickList" data-filter-list="1">
<view class="goods-select-row selected" data-toggle-check="1" data-status="fruit" data-tags="fruit,gift,active" data-search="蓝莓 高山 礼盒 4盒装" bindtap="handleToggleMock"><view class="check-dot active"><image class="icon-sm" mode="aspectFit" src="/assets/icons/check.svg" /></view><image class="goods-img sm" mode="aspectFill" src="/assets/goods/g2.svg" /><view><view class="product-title">高山蓝莓礼盒 4盒装</view><view class="product-sub">库存 168 · 原价 ¥298 · 活动价 ¥238</view></view></view>
<view class="goods-select-row selected" data-toggle-check="1" data-status="fruit" data-tags="fruit" data-search="时令果蔬 家庭装" bindtap="handleToggleMock"><view class="check-dot active"><image class="icon-sm" mode="aspectFit" src="/assets/icons/check.svg" /></view><image class="goods-img sm" mode="aspectFill" src="/assets/goods/g8.svg" /><view><view class="product-title">时令果蔬家庭装</view><view class="product-sub">库存 220 · 建议拼团价 ¥49</view></view></view>
<view class="goods-select-row" data-toggle-check="1" data-status="gift" data-tags="gift,low" data-search="山货 干货 礼盒" bindtap="handleToggleMock"><view class="check-dot"><image class="icon-sm" mode="aspectFit" src="/assets/icons/check.svg" /></view><image class="goods-img sm" mode="aspectFill" src="/assets/goods/g6.svg" /><view><view class="product-title">山货干货礼盒</view><view class="product-sub">库存 24 · 低库存提醒</view></view></view>
<view class="goods-select-row" data-toggle-check="1" data-status="fruit" data-tags="fruit" data-search="脆甜玉米 6根装" bindtap="handleToggleMock"><view class="check-dot"><image class="icon-sm" mode="aspectFit" src="/assets/icons/check.svg" /></view><image class="goods-img sm" mode="aspectFill" src="/assets/goods/g11.svg" /><view><view class="product-title">脆甜玉米 6根装</view><view class="product-sub">库存 360 · 可参加满减</view></view></view>
<view class="goods-select-row" data-toggle-check="1" data-status="gift" data-tags="gift" data-search="端午 礼品 装" bindtap="handleToggleMock"><view class="check-dot"><image class="icon-sm" mode="aspectFit" src="/assets/icons/check.svg" /></view><image class="goods-img sm" mode="aspectFill" src="/assets/goods/g12.svg" /><view><view class="product-title">端午特产礼品装</view><view class="product-sub">库存 82 · 建议优惠券活动</view></view></view><view class="list-empty">没有匹配商品</view>
</view><view class="bottom-actions"><button class="action-btn secondary" data-toast="已清空选择" bindtap="handleToast">清空</button><navigator class="action-btn" url="/pages/merchant-design/marketing-edit/marketing-edit">确认</navigator></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
