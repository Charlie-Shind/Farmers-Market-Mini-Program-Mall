<view class="app-page">
<view class="status-space"></view>
<view class="app-topbar"><navigator class="back-btn" url="/pages/merchant-design/shop/shop"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="search-pill"><image class="icon-sm" mode="aspectFit" src="/assets/icons/search.svg" /><input data-search-input="1" placeholder="搜索发布、订单、活动、提现问题" /></view></view>
<view class="action-strip"><button data-toast="商品发布说明" bindtap="handleToast"><view class="color-icon"><image class="icon" mode="aspectFit" src="/assets/icons/plus.svg" /></view><text>发布商品</text></button><button data-toast="订单处理说明" bindtap="handleToast"><view class="color-icon info"><image class="icon" mode="aspectFit" src="/assets/icons/order.svg" /></view><text>订单处理</text></button><button data-toast="活动配置说明" bindtap="handleToast"><view class="color-icon accent"><image class="icon" mode="aspectFit" src="/assets/icons/star.svg" /></view><text>活动配置</text></button><button data-toast="资金提现说明" bindtap="handleToast"><view class="color-icon warn"><image class="icon" mode="aspectFit" src="/assets/icons/wallet.svg" /></view><text>资金提现</text></button></view><view class="section-line-title"><text>常见问题</text></view><view class="full-list"><button class="notice-row" data-toast="已展开：规格库存说明" bindtap="handleToast"><text class="row-main"><text class="row-title">商品多规格怎么设置？</text><text class="row-desc">进入发布商品 - 规格库存，添加规格组和 规格组合</text></text><view class="row-right"><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></button><button class="notice-row" data-toast="已展开：活动选品说明" bindtap="handleToast"><text class="row-main"><text class="row-title">活动如何多选商品？</text><text class="row-desc">进入发布活动 - 参与商品，勾选商品后保存</text></text><view class="row-right"><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></button><button class="notice-row" data-toast="已展开：退款处理说明" bindtap="handleToast"><text class="row-main"><text class="row-title">退款申请怎么处理？</text><text class="row-desc">进入售后管理，查看买家原因和凭证后处理</text></text><view class="row-right"><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></button></view>
<view class="bottom-nav"><navigator url="/pages/merchant-design/dashboard/dashboard"><image class="icon" mode="aspectFit" src="/assets/icons/home.svg" /><text>首页</text></navigator><navigator url="/pages/merchant-design/messages/messages"><image class="icon" mode="aspectFit" src="/assets/icons/message.svg" /><text>聊天</text></navigator><navigator url="/pages/merchant-design/orders/orders"><image class="icon" mode="aspectFit" src="/assets/icons/order.svg" /><text>订单</text></navigator><navigator url="/pages/merchant-design/products/products"><image class="icon" mode="aspectFit" src="/assets/icons/box.svg" /><text>库存</text></navigator><navigator class="active" url="/pages/merchant-design/shop/shop"><image class="icon" mode="aspectFit" src="/assets/icons/user.svg" /><text>账号</text></navigator></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
