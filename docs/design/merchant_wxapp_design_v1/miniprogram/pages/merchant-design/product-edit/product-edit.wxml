<view class="app-page no-bottom with-sticky"><view class="status-space"></view>
<view class="page-titlebar"><navigator class="back-btn" url="/pages/merchant-design/products/products"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="title-block"><view class="page-title">编辑商品</view></view><navigator class="icon-action" url="/pages/merchant-design/product-drafts/product-drafts"><image class="icon" mode="aspectFit" src="/assets/icons/clock.svg" /><text>草稿</text></navigator></view>
<view class="segment"><view class="active" bindtap="handleToast">基础</view><navigator url="/pages/merchant-design/publish-images/publish-images">图片</navigator><navigator url="/pages/merchant-design/publish-sku/publish-sku">规格</navigator><view bindtap="handleToast">更多</view></view>
<view class="section-line-title"><text>商品图片</text><text class="row-right">最多 9 张</text></view>
<view class="photo-grid"><view class="photo-box"><image mode="aspectFill" src="/assets/goods/g2.svg" /><text class="tag">主图</text></view><view class="photo-box"><image mode="aspectFill" src="/assets/goods/g3.svg" /></view><button class="photo-box" data-toast="添加图片" bindtap="handleToast"><image class="icon" mode="aspectFit" src="/assets/icons/camera.svg" /></button><button class="photo-box" data-toast="继续添加图片" bindtap="handleToast"><image class="icon" mode="aspectFit" src="/assets/icons/plus.svg" /></button></view>
<view class="section-line-title"><text>商品视频</text><text class="row-right">可选</text></view>
<view class="media-upload-row"><view class="video-thumb"></view><view class="media-main"><view class="media-title">产地介绍视频</view><view class="media-meta">已上传 12 秒，可重新上传或删除</view></view><view class="btn-row"><button class="pill-btn outline" data-toast="重新上传视频" bindtap="handleToast">重传</button><button class="pill-btn danger" data-toast="已删除视频" bindtap="handleToast">删除</button></view></view>
<view class="section-line-title" id="basic"><text>商品信息</text></view><view class="form-line"><view><text>商品分类</text><text>可重选</text></view><input value="时令果蔬 / 新鲜水果" /></view><view class="form-line"><view><text>商品标题</text><text>必填</text></view><input value="湾源农仓 蓝莓礼盒 顺丰冷链装" /></view><view class="form-line"><view><text>商品副标题</text><text>选填</text></view><input value="产地直发，坏果包赔" /></view>
<view class="section-line-title"><text>价格与库存</text><navigator class="row-right" url="/pages/merchant-design/publish-sku/publish-sku">管理规格<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></navigator></view><view class="form-line"><view><text>销售价</text><text>必填</text></view><input value="268.00" /></view><view class="form-line"><view><text>划线价</text><text>选填</text></view><input value="318.00" /></view><view class="form-line"><view><text>总库存</text><text>自动汇总</text></view><input value="42" /></view>
<view class="section-line-title"><text>规格设置</text><navigator class="pill-btn" url="/pages/merchant-design/publish-sku/publish-sku">进入规格库存</navigator></view><view class="spec-editor"><view class="spec-block"><view class="spec-block-head"><view class="spec-block-title">当前模式</view><text class="status-pill success">多规格</text></view><view class="spec-option-wrap"><text class="spec-option active">重量</text><text class="spec-option active">包装</text><text class="spec-option active">配送</text></view></view></view>
<view class="section-line-title" id="extra"><text>服务标签</text><text class="row-right">可多选</text></view><view class="form-line"><view class="multi-chip-row"><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">坏果包赔</button><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">冷链直发</button><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">产地直发</button><button class="multi-chip" data-multi-chip="1" bindtap="handleToggleMock">现货速发</button></view></view>
<view class="section-line-title"><text>商品详情</text></view><view class="form-line"><view><text>详情描述</text><text>买家可见</text></view><textarea>蓝莓礼盒产地直发，果径均匀，适合家庭自食与节礼赠送。</textarea></view>
<view class="section-line-title"><text>更多信息</text><text class="row-right">已填 4 项</text></view><view class="form-line"><view><text>产地</text><text>必填</text></view><input value="云南·楚雄" /></view><view class="form-line"><view><text>溯源码</text><text>选填</text></view><input value="TRACE-YN-20260618" /></view><view class="form-line"><view><text>溯源说明</text><text>买家可见</text></view><textarea>本商品全程冷链配送，支持农药残留抽检合格验证。</textarea></view><view class="form-line"><view><text>预售模式</text><text>可切换</text></view><view class="multi-chip-row"><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">现货</button><button class="multi-chip" data-multi-chip="1" bindtap="handleToggleMock">开启预售</button></view></view>
<view class="bottom-actions three"><navigator class="action-btn secondary" url="/pages/merchant-design/product-drafts/product-drafts">草稿箱</navigator><button class="action-btn secondary" data-toast="已保存草稿" bindtap="handleToast">保存草稿</button><button class="action-btn" data-toast="已提交上架" bindtap="handleToast">保存并上架</button></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
