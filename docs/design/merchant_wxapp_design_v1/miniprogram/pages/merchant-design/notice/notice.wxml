<view class="app-page">
<view class="status-space"></view>
<view class="app-topbar"><navigator class="back-btn" url="/pages/merchant-design/dashboard/dashboard"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="search-pill"><image class="icon-sm" mode="aspectFit" src="/assets/icons/search.svg" /><input data-search-input="1" placeholder="搜索订单通知 / 官方通知" /></view></view>
<view class="tabs" data-filter-tabs="1"><button class="tab active" data-filter="all"><text>全部</text></button><button class="tab" data-filter="order"><text>订单</text></button><button class="tab" data-filter="official"><text>官方</text></button><button class="tab" data-filter="risk"><text>风险</text></button></view>
<view class="full-list" data-filter-list="1"><navigator class="notice-row" url="/pages/merchant-design/notice-order/notice-order"><view class="notice-type ok"><image class="icon-sm" mode="aspectFit" src="/assets/icons/order.svg" /></view><text class="row-main"><text class="row-title">你有 6 个订单待发货</text><text class="row-desc">建议 18:00 前完成发货 · 2分钟前</text></text><view class="row-right"><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></navigator><navigator class="notice-row" url="/pages/merchant-design/notice-official/notice-official"><view class="notice-type"><image class="icon-sm" mode="aspectFit" src="/assets/icons/bell.svg" /></view><text class="row-main"><text class="row-title">平台活动规则更新</text><text class="row-desc">秒杀活动库存锁定规则调整 · 今天</text></text><view class="row-right"><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></navigator><navigator class="notice-row" url="/pages/merchant-design/products/products"><view class="notice-type warn"><image class="icon-sm" mode="aspectFit" src="/assets/icons/box.svg" /></view><text class="row-main"><text class="row-title">3 个商品触发库存预警</text><text class="row-desc">低于安全库存 · 需要补货</text></text><view class="row-right"><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></navigator><navigator class="notice-row" url="/pages/merchant-design/refund/refund"><view class="notice-type bad"><image class="icon-sm" mode="aspectFit" src="/assets/icons/shield.svg" /></view><text class="row-main"><text class="row-title">1 个退款申请待处理</text><text class="row-desc">赵先生 · 仅退款 ¥76.00</text></text><view class="row-right"><image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></navigator><view class="list-empty">没有匹配通知</view></view>
<view class="bottom-nav"><navigator class="active" url="/pages/merchant-design/dashboard/dashboard"><image class="icon" mode="aspectFit" src="/assets/icons/home.svg" /><text>首页</text></navigator><navigator url="/pages/merchant-design/messages/messages"><image class="icon" mode="aspectFit" src="/assets/icons/message.svg" /><text>聊天</text></navigator><navigator url="/pages/merchant-design/orders/orders"><image class="icon" mode="aspectFit" src="/assets/icons/order.svg" /><text>订单</text></navigator><navigator url="/pages/merchant-design/products/products"><image class="icon" mode="aspectFit" src="/assets/icons/box.svg" /><text>库存</text></navigator><navigator url="/pages/merchant-design/shop/shop"><image class="icon" mode="aspectFit" src="/assets/icons/user.svg" /><text>账号</text></navigator></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
