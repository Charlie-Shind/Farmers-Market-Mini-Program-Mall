<view class="app-page no-bottom with-sticky">
<view class="status-space"></view>
<view class="page-titlebar"><navigator class="back-btn" url="/pages/merchant-design/products/products"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></navigator><view class="title-block"><view class="page-title">发布商品</view></view></view>
<view class="section-line-title"><text>商品图片</text><navigator class="row-right" url="/pages/merchant-design/publish-images/publish-images">管理图片<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></navigator></view>
<view class="photo-strip"><view class="photo-thumb"><image mode="aspectFill" src="/assets/goods/g2.svg" /><text class="mini-label">主图</text></view><view class="photo-thumb"><image mode="aspectFill" src="/assets/goods/g11.svg" /></view><view class="photo-thumb"><image mode="aspectFill" src="/assets/goods/g13.svg" /></view><navigator class="photo-add" url="/pages/merchant-design/publish-images/publish-images"><image class="icon" mode="aspectFit" src="/assets/icons/camera.svg" /></navigator></view>
<view class="section-line-title"><text>商品视频</text><text class="row-right">可选</text></view><view class="media-upload-row"><view class="video-thumb"></view><view class="media-main"><view class="media-title">上传商品视频</view><view class="media-meta">支持产地、开箱、商品细节展示</view></view><button class="pill-btn primary" data-toast="已选择视频文件" bindtap="handleToast">上传</button></view>
<view class="full-list"><navigator class="notice-row" url="/pages/merchant-design/publish-category/publish-category"><view class="row-main"><view class="row-title">商品分类</view><view class="row-desc">时令果蔬 / 蓝莓鲜果</view></view><view class="row-right">修改<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></navigator><view class="form-line"><view>商品标题<text>必填</text></view><input value="高山蓝莓礼盒 4盒装" /></view><view class="form-line"><view>副标题<text>卖点</text></view><input value="产地直发，当日采摘，顺丰冷链" /></view><view class="form-line"><view>商品详情<text>图文详情</text></view><textarea>适合家庭分享与企业礼赠，果径均匀，酸甜适中。</textarea></view></view>
<view class="section-line-title"><text>价格库存</text><navigator class="row-right" url="/pages/merchant-design/publish-sku/publish-sku">规格库存<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></navigator></view><view class="data-grid-3"><view class="data-cell"><text>¥298</text><text>销售价</text></view><view class="data-cell"><text>168</text><text>库存</text></view><view class="data-cell"><text>1.5kg</text><text>重量</text></view></view>
<view class="section-line-title"><text>规格模式</text></view><view class="segment"><button class="active" data-toast="已选择多规格" bindtap="handleToast">多规格</button><button data-toast="已切换单规格" bindtap="handleToast">单规格</button><navigator url="/pages/merchant-design/publish-sku/publish-sku">编辑规格</navigator></view>
<view class="section-line-title"><text>服务标签多选</text></view><view class="panel-line"><view class="multi-chip-row"><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">产地直发</button><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">顺丰冷链</button><button class="multi-chip" data-multi-chip="1" bindtap="handleToggleMock">坏果包赔</button><button class="multi-chip" data-multi-chip="1" bindtap="handleToggleMock">有机认证</button><button class="multi-chip active" data-multi-chip="1" bindtap="handleToggleMock">48小时发货</button></view></view>
<view class="section-line-title"><text>更多设置</text></view><view class="full-list"><view class="switch-row"><text class="switch-main"><text>开启预售</text><text>设置发货周期和预售库存</text></text><button class="fake-switch" data-switch="1" bindtap="toggleSwitch"></button></view><view class="switch-row"><text class="switch-main"><text>启用溯源码</text><text>展示产地、采摘、质检信息</text></text><button class="fake-switch active" data-switch="1" bindtap="toggleSwitch"></button></view><view class="switch-row"><text class="switch-main"><text>商品视频</text><text>上传 15 秒产地介绍视频</text></text><button class="fake-switch" data-switch="1" bindtap="toggleSwitch"></button></view></view>
<view class="bottom-actions three"><button class="action-btn secondary" data-toast="已保存商品草稿" bindtap="handleToast">存草稿</button><navigator class="action-btn secondary" url="/pages/merchant-design/product-drafts/product-drafts">草稿箱</navigator><button class="action-btn" data-toast="已提交上架审核" bindtap="handleToast">提交上架</button></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
