<view class="app-page no-bottom with-sticky">
<view class="status-space"></view>
<view class="page-titlebar">
<view class="back-btn" bindtap="goBack"><image class="icon" mode="aspectFit" src="/assets/icons/back.svg" /></view><view class="title-block"><view class="page-title">提现</view><view class="page-subtitle">预计 1 到 3 个工作日到账</view></view>
</view>
<view class="metric-strip"><view class="metric-item" style="grid-column: span 3"><view class="metric-value">¥8,920.00</view><view class="metric-label">当前可提现金额</view></view></view>
<view class="form-section"><view class="form-section-title">提现金额</view><view class="toolbar" style="padding:0;border:0"><button class="chip active">全部提现</button><button class="chip">¥500</button><button class="chip">¥1000</button><button class="chip">自定义</button></view><view class="field"><view class="field-label"><text>自定义金额</text><text>单位：元</text></view><input value="8920.00" /></view></view>
<view class="form-section"><view class="form-section-title">到账账户</view><button class="setting-row" style="padding-left:0;padding-right:0;width:100%" data-open-sheet="accountSheet" bindtap="openSheet"><view class="row-main"><view class="row-title">微信商家零钱</view><view class="row-desc">已绑定，尾号 8912</view></view><view class="row-right">切换<image class="icon-sm" mode="aspectFit" src="/assets/icons/chevron.svg" /></view></button></view>
<view class="divider"></view><view class="section-line-title">提现记录</view><view class="full-list"><view class="finance-row"><view><view class="row-title">2026-06-16</view><view class="row-desc">已到账</view></view><text>¥2,000.00</text></view><view class="finance-row"><view><view class="row-title">2026-06-10</view><view class="row-desc">已到账</view></view><text>¥1,500.00</text></view></view><view class="bottom-actions"><button class="action-btn" data-toast="已提交提现申请" bindtap="handleToast">提交提现申请</button></view>
<view class="sheet-mask {{activeSheet ? 'show' : ''}}" data-sheet-mask="1" bindtap="closeSheet"></view><view class="sheet {{activeSheet === 'accountSheet' ? 'show' : ''}}" id="accountSheet"><view class="sheet-head"><view class="sheet-title">选择到账账户</view><button class="icon-btn" data-close-sheet="1" bindtap="closeSheet"><image class="icon" mode="aspectFit" src="/assets/icons/close.svg" /></button></view><view class="sheet-group"><view class="sheet-label">账户</view><view class="option-grid"><button class="option active">微信商家零钱</button><button class="option">对公银行卡</button><button class="option">微信零钱</button></view></view><view class="bottom-actions" style="position:static;transform:none;padding:0;border-top:0"><button class="action-btn secondary" data-toast="已重置筛选" bindtap="handleToast">重置</button><button class="action-btn" data-toast="已应用筛选" data-close-sheet="1" bindtap="handleToast" bindtap="closeSheet">应用筛选</button></view></view>
</view>

<view class="toast {{toastText ? 'show' : ''}}">{{toastText}}</view>
